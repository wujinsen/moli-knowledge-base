# kb-orchestrator — copy to .env or export in shell

# auto = use LLM when key present, else mock (default)
# STUDIO_AGENT_MODE=auto
# STUDIO_AGENT_MODE=llm
# STUDIO_AGENT_MODE=mock

# OpenAI or any OpenAI-compatible API
STUDIO_LLM_API_KEY=
# STUDIO_LLM_BASE_URL=https://api.openai.com/v1
# STUDIO_LLM_MODEL=gpt-4o-mini
# STUDIO_LLM_MAX_TOOL_ROUNDS=8

# Optional: override novels root
# NOVELS_ROOT=../classical-novels

# Dry-run apply (no disk writes)
# STUDIO_DRY_RUN=1
