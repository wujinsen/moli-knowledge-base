---
import { likeItemHref } from '../lib/bestiary';

interface Props {
  href: string;
  name: string;
  type: string;
  bookSlug?: string;
  faction?: string;
  summary?: string;
  tags?: string[];
  proximity?: string;
  backing?: string;
  attach?: string;
  outcome?: string;
  personality?: string;
  likes?: string[];
}
const {
  href,
  name,
  type,
  bookSlug,
  faction,
  summary,
  tags = [],
  proximity,
  backing,
  attach,
  outcome,
  personality,
  likes = [],
} = Astro.props;
const hasFields = !!(personality || likes.length > 0 || backing || attach || outcome);
const subline = [faction, proximity].filter(Boolean).join(' · ');
---

<div class="bestiary-card">
  <a href={href} class="bestiary-card-hit" aria-label={name}></a>
  <div class="bestiary-card-inner">
    <header class="bestiary-card-head">
      <div class="bestiary-card-title-row">
        <h3 class="bestiary-card-name">{name}</h3>
        <span class={`bestiary-badge ${type === 'monster' ? 'bestiary-badge--monster' : 'bestiary-badge--char'}`}>
          {type === 'monster' ? '妖怪' : '人物'}
        </span>
      </div>
      {subline && <p class="bestiary-card-sub">{subline}</p>}
    </header>

    {summary && <p class="bestiary-card-summary">{summary}</p>}

    {
      (hasFields) && (
        <div class="bestiary-card-fields">
          {
            personality && (
              <div class="bestiary-card-row">
                <span class="bestiary-card-label">性格</span>
                <p class="bestiary-card-value">{personality}</p>
              </div>
            )
          }
          {
            likes.length > 0 && (
              <div class="bestiary-card-row bestiary-card-row--chips">
                <span class="bestiary-card-label">喜好</span>
                <div class="bestiary-card-chips">
                  {likes.map((like) => {
                    const itemHref = bookSlug ? likeItemHref(bookSlug, like) : null;
                    return itemHref ? (
                      <a class="chip chip-like pointer-events-auto" href={itemHref}>
                        {like}
                      </a>
                    ) : (
                      <span class="chip chip-like">{like}</span>
                    );
                  })}
                </div>
              </div>
            )
          }
          {
            backing && (
              <div class="bestiary-card-row">
                <span class="bestiary-card-label">靠山</span>
                <p class="bestiary-card-value">{backing}</p>
              </div>
            )
          }
          {
            attach && (
              <div class="bestiary-card-row">
                <span class="bestiary-card-label">依附</span>
                <p class="bestiary-card-value">{attach}</p>
              </div>
            )
          }
          {
            outcome && (
              <div class="bestiary-card-row">
                <span class="bestiary-card-label">结局</span>
                <p class="bestiary-card-value">{outcome}</p>
              </div>
            )
          }
        </div>
      )
    }

    {
      tags.length > 0 && (
        <footer class="bestiary-card-foot">
          <div class="bestiary-card-chips">
            {tags.map((t) => (
              <span class="chip chip-foot">{t}</span>
            ))}
          </div>
        </footer>
      )
    }
  </div>
</div>
