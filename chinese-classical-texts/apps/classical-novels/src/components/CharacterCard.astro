---
import { likeItemHref } from '../lib/bestiary';

interface Props {
  href: string;
  name: string;
  type: string;
  bookSlug?: string;
  faction?: string;
  summary?: string;
  tags?: string[];
  proximity?: string;
  backing?: string;
  attach?: string;
  outcome?: string;
  personality?: string;
  likes?: string[];
}
const {
  href,
  name,
  type,
  bookSlug,
  faction,
  summary,
  tags = [],
  proximity,
  backing,
  attach,
  outcome,
  personality,
  likes = [],
} = Astro.props;
const hasJpmMeta = !!(proximity || backing || attach || outcome);
const hasHlmMeta = !!(personality || likes.length > 0);
const hasItemLinks = likes.some((like) => bookSlug && likeItemHref(bookSlug, like));
---

<div
  class="bestiary-card relative flex h-full min-h-[15.5rem] flex-col rounded-lg border p-4 transition hover:shadow-md sm:p-5"
  style="border-color: var(--line); background: var(--surface)"
>
  <a href={href} class="absolute inset-0 z-0 rounded-lg" aria-label={name}></a>
  <div class={`relative flex min-h-0 flex-1 flex-col ${hasItemLinks ? 'z-10' : 'pointer-events-none'}`}>
    <header class="shrink-0">
      <div class="flex items-start justify-between gap-2">
        <h3 class="text-lg font-bold leading-tight" style="color: var(--primary)">{name}</h3>
        <span
          class={`shrink-0 rounded px-2 py-0.5 text-xs font-medium ${
            type === 'monster' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700'
          }`}
        >
          {type === 'monster' ? '妖怪' : '人物'}
        </span>
      </div>
      {(faction || proximity) && (
        <p class="mt-1 text-xs leading-relaxed" style="color: color-mix(in srgb, var(--ink) 50%, var(--ink-soft))">
          {[faction, proximity].filter(Boolean).join(' · ')}
        </p>
      )}
    </header>

    {summary && (
      <p class="mt-2.5 line-clamp-2 text-sm leading-relaxed" style="color: var(--ink)">
        {summary}
      </p>
    )}

    {
      hasHlmMeta && (
        <dl class="mt-3 space-y-2.5 text-sm leading-relaxed" style="color: var(--ink)">
          {personality && (
            <div class="grid grid-cols-[2.75rem_minmax(0,1fr)] items-start gap-x-2">
              <dt class="pt-0.5 font-medium" style="color: var(--accent)">性格</dt>
              <dd class="line-clamp-2 min-w-0">{personality}</dd>
            </div>
          )}
          {likes.length > 0 && (
            <div>
              <dt class="font-medium" style="color: var(--accent)">喜好</dt>
              <dd class="mt-1.5 flex flex-wrap gap-1.5">
                {likes.map((like) => {
                  const itemHref = bookSlug ? likeItemHref(bookSlug, like) : null;
                  return itemHref ? (
                    <a class="chip chip-like pointer-events-auto text-xs hover:underline" href={itemHref}>
                      {like}
                    </a>
                  ) : (
                    <span class="chip chip-like text-xs">{like}</span>
                  );
                })}
              </dd>
            </div>
          )}
        </dl>
      )
    }
    {
      hasJpmMeta && (
        <dl class="mt-3 space-y-2.5 text-sm leading-relaxed" style="color: var(--ink)">
          {backing && (
            <div class="grid grid-cols-[2.75rem_minmax(0,1fr)] items-start gap-x-2">
              <dt class="pt-0.5 font-medium" style="color: var(--accent)">靠山</dt>
              <dd class="line-clamp-2 min-w-0">{backing}</dd>
            </div>
          )}
          {attach && (
            <div class="grid grid-cols-[2.75rem_minmax(0,1fr)] items-start gap-x-2">
              <dt class="pt-0.5 font-medium" style="color: var(--accent)">依附</dt>
              <dd class="line-clamp-2 min-w-0">{attach}</dd>
            </div>
          )}
          {outcome && (
            <div class="grid grid-cols-[2.75rem_minmax(0,1fr)] items-start gap-x-2">
              <dt class="pt-0.5 font-medium" style="color: var(--accent)">结局</dt>
              <dd class="line-clamp-2 min-w-0">{outcome}</dd>
            </div>
          )}
        </dl>
      )
    }

    {
      tags.length > 0 && (
        <div
          class="mt-auto shrink-0 border-t pt-3"
          style="border-color: color-mix(in srgb, var(--line) 85%, transparent)"
        >
          <div class="flex flex-wrap gap-1.5">
            {tags.map((t) => (
              <span class="chip chip-foot text-xs">{t}</span>
            ))}
          </div>
        </div>
      )
    }
  </div>
</div>
