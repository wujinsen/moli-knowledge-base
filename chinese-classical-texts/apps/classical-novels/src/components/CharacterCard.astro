---
import BestiaryLinkChips from './BestiaryLinkChips.astro';
import { chipHref, keyItemsLabel } from '../lib/bestiary';

interface Props {
  href: string;
  name: string;
  type: string;
  bookSlug?: string;
  placeIds?: string[];
  faction?: string;
  summary?: string;
  tags?: string[];
  outcome?: string;
  likes?: string[];
  keyItems?: string[];
  costumes?: string[];
}
const {
  href,
  name,
  type,
  bookSlug,
  placeIds = [],
  faction,
  summary,
  tags = [],
  outcome,
  likes = [],
  keyItems = [],
  costumes = [],
} = Astro.props;
const subline = faction ?? '';
const placeIdSet = new Set(placeIds);
const hasDetailFields =
  outcome || costumes.length > 0 || keyItems.length > 0 || (bookSlug && likes.length > 0);
---

<div class="bestiary-card bestiary-card--compact">
  <a href={href} class="bestiary-card-hit" aria-label={name}></a>
  <div class="bestiary-card-inner">
    <header class="bestiary-card-head">
      <div class="bestiary-card-title-row">
        <h3 class="bestiary-card-name">{name}</h3>
        <span class={`bestiary-badge ${type === 'monster' ? 'bestiary-badge--monster' : 'bestiary-badge--char'}`}>
          {type === 'monster' ? '妖怪' : '人物'}
        </span>
      </div>
      {subline && <p class="bestiary-card-sub">{subline}</p>}
    </header>

    {summary && <p class="bestiary-card-summary">{summary}</p>}

    {
      hasDetailFields && (
        <div class="bestiary-card-fields">
          {
            outcome && (
              <div class="bestiary-card-field">
                <span class="bestiary-card-label">结局</span>
                <p class="bestiary-card-value">{outcome}</p>
              </div>
            )
          }
          {
            costumes.length > 0 && bookSlug && (
              <div class="bestiary-card-field">
                <span class="bestiary-card-label">服饰</span>
                <BestiaryLinkChips bookSlug={bookSlug} items={costumes} />
              </div>
            )
          }
          {
            keyItems.length > 0 && bookSlug && (
              <div class="bestiary-card-field">
                <span class="bestiary-card-label">{bookSlug ? keyItemsLabel(bookSlug) : '关键物品'}</span>
                <BestiaryLinkChips bookSlug={bookSlug} items={keyItems} />
              </div>
            )
          }
          {
            likes.length > 0 && bookSlug && (
              <div class="bestiary-card-field">
                <span class="bestiary-card-label">喜好</span>
                <BestiaryLinkChips bookSlug={bookSlug} items={likes} />
              </div>
            )
          }
        </div>
      )
    }

    {
      tags.length > 0 && (
        <footer class="bestiary-card-foot">
          <div class="bestiary-card-chips">
            {tags.slice(0, 3).map((t) => {
              const tagHref = bookSlug ? chipHref(bookSlug, t, placeIdSet) : null;
              return tagHref ? (
                <a class="chip chip-foot chip-link pointer-events-auto" href={tagHref}>
                  {t}
                </a>
              ) : (
                <span class="chip chip-foot">{t}</span>
              );
            })}
          </div>
        </footer>
      )
    }
  </div>
</div>
