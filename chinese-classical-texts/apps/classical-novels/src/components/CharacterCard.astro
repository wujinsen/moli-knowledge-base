---
interface Props {
  href: string;
  name: string;
  type: string;
  faction?: string;
  summary?: string;
  tags?: string[];
  proximity?: string;
  backing?: string;
  attach?: string;
  outcome?: string;
}
const { href, name, type, faction, summary, tags = [], proximity, backing, attach, outcome } =
  Astro.props;
const hasJpmMeta = !!(proximity || backing || attach || outcome);
---

<a
  href={href}
  class="block rounded-lg border p-4 transition hover:shadow-md"
  style="border-color: var(--line); background: var(--surface)"
>
  <div class="flex items-center justify-between gap-2">
    <h3 class="text-lg font-bold" style="color: var(--primary)">{name}</h3>
    <span
      class={`shrink-0 rounded px-2 py-0.5 text-xs ${
        type === 'monster' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700'
      }`}
    >
      {type === 'monster' ? '妖怪' : '人物'}
    </span>
  </div>
  {(faction || proximity) && (
    <p class="mt-1 text-xs" style="color: var(--ink-soft)">
      {[faction, proximity].filter(Boolean).join(' · ')}
    </p>
  )}
  {summary && <p class="mt-2 line-clamp-3 text-sm" style="color: var(--ink-soft)">{summary}</p>}
  {
    hasJpmMeta && (
      <dl class="mt-3 space-y-1 text-xs" style="color: var(--ink)">
        {backing && (
          <div class="flex gap-1.5">
            <dt class="shrink-0 font-medium" style="color: var(--accent)">靠山</dt>
            <dd class="line-clamp-2">{backing}</dd>
          </div>
        )}
        {attach && (
          <div class="flex gap-1.5">
            <dt class="shrink-0 font-medium" style="color: var(--accent)">依附</dt>
            <dd class="line-clamp-2">{attach}</dd>
          </div>
        )}
        {outcome && (
          <div class="flex gap-1.5">
            <dt class="shrink-0 font-medium" style="color: var(--accent)">结局</dt>
            <dd class="line-clamp-2">{outcome}</dd>
          </div>
        )}
      </dl>
    )
  }
  {
    tags.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1">
        {tags.map((t) => (
          <span class="chip text-xs">{t}</span>
        ))}
      </div>
    )
  }
</a>
