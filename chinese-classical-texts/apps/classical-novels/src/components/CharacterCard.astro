---
interface Props {
  href: string;
  name: string;
  type: string;
  faction?: string;
  summary?: string;
  tags?: string[];
}
const { href, name, type, faction, summary, tags = [] } = Astro.props;
---

<a
  href={href}
  class="block rounded-lg border border-stone-300 bg-white p-4 transition hover:shadow-md"
>
  <div class="flex items-center justify-between">
    <h3 class="text-lg font-bold text-stone-800">{name}</h3>
    <span
      class={`rounded px-2 py-0.5 text-xs ${
        type === 'monster' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700'
      }`}
    >
      {type === 'monster' ? '妖怪' : '人物'}
    </span>
  </div>
  {faction && <p class="mt-1 text-xs text-stone-500">{faction}</p>}
  {summary && <p class="mt-2 line-clamp-3 text-sm text-stone-600">{summary}</p>}
  {
    tags.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1">
        {tags.map((t) => (
          <span class="rounded bg-stone-100 px-1.5 py-0.5 text-xs text-stone-500">{t}</span>
        ))}
      </div>
    )
  }
</a>
