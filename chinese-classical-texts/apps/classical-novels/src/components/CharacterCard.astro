---
import { likeItemHref } from '../lib/bestiary';

interface Props {
  href: string;
  name: string;
  type: string;
  bookSlug?: string;
  faction?: string;
  summary?: string;
  tags?: string[];
  proximity?: string;
  backing?: string;
  attach?: string;
  outcome?: string;
  personality?: string;
  likes?: string[];
}
const {
  href,
  name,
  type,
  bookSlug,
  faction,
  summary,
  tags = [],
  proximity,
  backing,
  attach,
  outcome,
  personality,
  likes = [],
} = Astro.props;
const hasJpmMeta = !!(proximity || backing || attach || outcome);
const hasHlmMeta = !!(personality || likes.length > 0);
---

<div class="bestiary-card relative flex h-full flex-col rounded-lg border p-4 transition sm:p-5">
  <a href={href} class="absolute inset-0 z-0 rounded-lg" aria-label={name}></a>
  <div class="relative z-10 flex min-h-0 flex-1 flex-col pointer-events-none">
    <header class="shrink-0">
      <div class="flex items-start justify-between gap-2">
        <h3 class="text-lg font-bold leading-tight" style="color: var(--primary)">{name}</h3>
        <span class={`bestiary-badge shrink-0 ${type === 'monster' ? 'bestiary-badge--monster' : 'bestiary-badge--char'}`}>
          {type === 'monster' ? '妖怪' : '人物'}
        </span>
      </div>
      {(faction || proximity) && (
        <p class="bestiary-card-sub mt-1">{[faction, proximity].filter(Boolean).join(' · ')}</p>
      )}
    </header>

    {summary && <p class="bestiary-card-summary mt-2 line-clamp-2">{summary}</p>}

    {
      hasHlmMeta && (
        <dl class="bestiary-card-meta mt-3 space-y-2">
          {personality && (
            <div class="grid grid-cols-[3rem_minmax(0,1fr)] items-start gap-x-2">
              <dt class="pt-0.5">性格</dt>
              <dd class="line-clamp-2 min-w-0">{personality}</dd>
            </div>
          )}
          {likes.length > 0 && (
            <div>
              <dt>喜好</dt>
              <dd class="mt-1 flex flex-wrap gap-1.5">
                {likes.map((like) => {
                  const itemHref = bookSlug ? likeItemHref(bookSlug, like) : null;
                  return itemHref ? (
                    <a class="chip chip-like pointer-events-auto hover:underline" href={itemHref}>
                      {like}
                    </a>
                  ) : (
                    <span class="chip chip-like">{like}</span>
                  );
                })}
              </dd>
            </div>
          )}
        </dl>
      )
    }
    {
      hasJpmMeta && (
        <dl class="bestiary-card-meta mt-3 space-y-2">
          {backing && (
            <div class="grid grid-cols-[3rem_minmax(0,1fr)] items-start gap-x-2">
              <dt class="pt-0.5">靠山</dt>
              <dd class="line-clamp-2 min-w-0">{backing}</dd>
            </div>
          )}
          {attach && (
            <div class="grid grid-cols-[3rem_minmax(0,1fr)] items-start gap-x-2">
              <dt class="pt-0.5">依附</dt>
              <dd class="line-clamp-2 min-w-0">{attach}</dd>
            </div>
          )}
          {outcome && (
            <div class="grid grid-cols-[3rem_minmax(0,1fr)] items-start gap-x-2">
              <dt class="pt-0.5">结局</dt>
              <dd class="line-clamp-2 min-w-0">{outcome}</dd>
            </div>
          )}
        </dl>
      )
    }

    {
      tags.length > 0 && (
        <div class="bestiary-card-tags mt-auto shrink-0 border-t pt-3">
          <div class="flex flex-wrap gap-1.5">
            {tags.map((t) => (
              <span class="chip chip-foot">{t}</span>
            ))}
          </div>
        </div>
      )
    }
  </div>
</div>
