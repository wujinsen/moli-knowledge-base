---
import type { BookModule } from '../lib/books';

interface Props {
  module: BookModule;
  bookName: string;
  bookSlug: string;
}

const { module: mod, bookName, bookSlug } = Astro.props;
---

<section class="module-context surface" aria-label="当前模块">
  <span class="glyph module-context-glyph">{mod.glyph}</span>
  <div class="min-w-0 flex-1">
    <p class="module-context-book tracking-wide">{bookName}</p>
    <h1
      class="brand text-2xl sm:text-3xl"
      style="color: var(--primary)"
      data-i18n={`modules.${bookSlug}.${mod.key}.title`}
    >
      {mod.title}
    </h1>
    <p
      class="module-context-desc mt-1.5 leading-relaxed"
      data-i18n={`modules.${bookSlug}.${mod.key}.desc`}
    >
      {mod.desc}
    </p>
    <slot />
  </div>
</section>
