---
/** 阅读页：浅色/深色 + 滚动/双栏 + 字号 + 行距 + 分段 */
---

<div class="reader-toolbar surface" data-pagefind-ignore role="toolbar" aria-label="阅读设置">
  <div class="reader-toolbar-group" role="group" aria-label="配色">
    <span class="reader-toolbar-label">配色</span>
    <button type="button" class="reader-toggle" data-reader-theme="light" aria-pressed="true" title="白底阅读">浅色</button>
    <button type="button" class="reader-toggle" data-reader-theme="dark" aria-pressed="false" title="暗色阅读">深色</button>
  </div>
  <span class="reader-toolbar-divider" aria-hidden="true"></span>
  <div class="reader-toolbar-group" role="group" aria-label="版式">
    <span class="reader-toolbar-label">版式</span>
    <button type="button" class="reader-toggle" data-reader-layout="scroll" aria-pressed="true">滚动</button>
    <button type="button" class="reader-toggle" data-reader-layout="columns" aria-pressed="false">双栏</button>
  </div>
  <span class="reader-toolbar-divider" aria-hidden="true"></span>
  <div class="reader-toolbar-group" role="group" aria-label="字号">
    <span class="reader-toolbar-label">字号</span>
    <button type="button" class="reader-toggle" data-reader-font="sm" aria-pressed="false" title="较小">小</button>
    <button type="button" class="reader-toggle" data-reader-font="md" aria-pressed="true" title="默认">标准</button>
    <button type="button" class="reader-toggle" data-reader-font="lg" aria-pressed="false" title="较大">大</button>
    <button type="button" class="reader-toggle" data-reader-font="xl" aria-pressed="false" title="特大">特大</button>
  </div>
  <span class="reader-toolbar-divider" aria-hidden="true"></span>
  <div class="reader-toolbar-group" role="group" aria-label="行距">
    <span class="reader-toolbar-label">行距</span>
    <button type="button" class="reader-toggle" data-reader-leading="compact" aria-pressed="false" title="行距较紧">紧凑</button>
    <button type="button" class="reader-toggle" data-reader-leading="normal" aria-pressed="false" title="适中">标准</button>
    <button type="button" class="reader-toggle" data-reader-leading="relaxed" aria-pressed="true" title="默认，适合长段阅读">疏朗</button>
    <button type="button" class="reader-toggle" data-reader-leading="loose" aria-pressed="false" title="行距最宽">很疏</button>
  </div>
  <span class="reader-toolbar-divider" aria-hidden="true"></span>
  <div class="reader-toolbar-group" role="group" aria-label="分段">
    <span class="reader-toolbar-label">分段</span>
    <button type="button" class="reader-toggle" data-reader-segments="off" aria-pressed="false" title="整段连续阅读">连续</button>
    <button type="button" class="reader-toggle" data-reader-segments="para" aria-pressed="true" title="按章回体例拆段（话说、却说等）">段落</button>
    <button type="button" class="reader-toggle" data-reader-segments="clause" aria-pressed="false" title="按句号逐句分行">句读</button>
  </div>
</div>

<script>
  import {
    CHAPTER_BODY_SELECTOR,
    CHAPTER_TEXT_SELECTOR,
    extractParagraphPlain,
    normalizeSegmentMode,
    paragraphNeedsSplit,
    splitParagraphText,
    splitTextToClauses,
  } from '../lib/readerParagraphs';

  const STORAGE_THEME = 'reader-theme';
  const STORAGE_LAYOUT = 'reader-layout';
  const STORAGE_FONT = 'reader-font-size';
  const STORAGE_LEADING = 'reader-leading';
  const STORAGE_SEGMENTS = 'reader-segments';
  const STORAGE_SEGMENTS_MIGRATION = 'reader-segments-v2';
  const FONT_LEVELS = ['sm', 'md', 'lg', 'xl'];
  const LEADING_LEVELS = ['compact', 'normal', 'relaxed', 'loose'];

  function normalizeFont(raw) {
    return FONT_LEVELS.includes(raw) ? raw : 'md';
  }

  function normalizeTheme(raw) {
    if (raw === 'dark' || raw === 'night' || raw === '夜间' || raw === '黯') return 'dark';
    return 'light';
  }

  function normalizeLeading(raw) {
    return LEADING_LEVELS.includes(raw) ? raw : 'relaxed';
  }

  function shell() {
    return document.getElementById('reader-shell');
  }

  function chapterBody() {
    return document.querySelector(CHAPTER_BODY_SELECTOR);
  }

  function ensureBodySnapshot(body) {
    if (!body.dataset.readerOriginal) {
      body.dataset.readerOriginal = body.innerHTML;
    }
  }

  function restoreBody(body) {
    const original = body.dataset.readerOriginal;
    if (original != null) {
      body.innerHTML = original;
    }
  }

  function clauseParagraph(p) {
    if (p.dataset.readerClause === 'true') return;
    const fragments = [];
    for (const node of p.childNodes) {
      if (node.nodeType === Node.TEXT_NODE) {
        for (const part of splitTextToClauses(node.textContent ?? '')) {
          const span = document.createElement('span');
          span.className = 'reader-seg';
          span.textContent = part;
          fragments.push(span);
        }
      } else if (node instanceof HTMLElement) {
        fragments.push(node.cloneNode(true));
      }
    }
    p.dataset.readerClauseOriginal = p.innerHTML;
    p.replaceChildren(...fragments);
    p.dataset.readerClause = 'true';
  }

  function restoreClauseParagraph(p) {
    if (p.dataset.readerClause !== 'true') return;
    const original = p.dataset.readerClauseOriginal;
    if (original != null) {
      p.innerHTML = original;
    }
    delete p.dataset.readerClauseOriginal;
    delete p.dataset.readerClause;
  }

  function splitParagraphElements(body) {
    const ps = [...body.querySelectorAll(':scope > p:not(.reader-zhipi-hint)')];
    for (const p of ps) {
      if (!paragraphNeedsSplit(p)) continue;
      const parts = splitParagraphText(extractParagraphPlain(p));
      if (parts.length <= 1) continue;
      const created = parts.map((text) => {
        const np = document.createElement('p');
        np.className = 'reader-para';
        np.textContent = text;
        return np;
      });
      p.replaceWith(...created);
    }
  }

  function applySegmentMode(mode) {
    const next = normalizeSegmentMode(mode);
    const s = shell();
    const body = chapterBody();
    if (!body) return;

    if (s) {
      s.dataset.readerSegments = next;
      try {
        localStorage.setItem(STORAGE_SEGMENTS, next);
      } catch (_) {}
    }

    ensureBodySnapshot(body);
    restoreBody(body);

    if (next === 'para') {
      splitParagraphElements(body);
    } else if (next === 'clause') {
      for (const p of body.querySelectorAll(CHAPTER_TEXT_SELECTOR)) {
        clauseParagraph(p);
      }
    }

    syncButtons();
  }

  function syncButtons() {
    const s = shell();
    if (!s) return;
    const theme = s.dataset.readerTheme ?? 'light';
    const layout = s.dataset.readerLayout ?? 'scroll';
    document.querySelectorAll('[data-reader-theme]').forEach((btn) => {
      const pressed = btn.getAttribute('data-reader-theme') === theme;
      btn.setAttribute('aria-pressed', pressed ? 'true' : 'false');
      btn.classList.toggle('is-active', pressed);
    });
    document.querySelectorAll('[data-reader-layout]').forEach((btn) => {
      const pressed = btn.getAttribute('data-reader-layout') === layout;
      btn.setAttribute('aria-pressed', pressed ? 'true' : 'false');
      btn.classList.toggle('is-active', pressed);
    });
    const font = s.dataset.readerFontSize ?? 'md';
    document.querySelectorAll('[data-reader-font]').forEach((btn) => {
      const pressed = btn.getAttribute('data-reader-font') === font;
      btn.setAttribute('aria-pressed', pressed ? 'true' : 'false');
      btn.classList.toggle('is-active', pressed);
    });
    const leading = s.dataset.readerLeading ?? 'relaxed';
    document.querySelectorAll('[data-reader-leading]').forEach((btn) => {
      const pressed = btn.getAttribute('data-reader-leading') === leading;
      btn.setAttribute('aria-pressed', pressed ? 'true' : 'false');
      btn.classList.toggle('is-active', pressed);
    });
    const segments = normalizeSegmentMode(s.dataset.readerSegments ?? 'para');
    document.querySelectorAll('[data-reader-segments]').forEach((btn) => {
      const pressed = btn.getAttribute('data-reader-segments') === segments;
      btn.setAttribute('aria-pressed', pressed ? 'true' : 'false');
      btn.classList.toggle('is-active', pressed);
    });
  }

  function applyTheme(theme) {
    const s = shell();
    if (!s) return;
    const next = normalizeTheme(theme);
    s.dataset.readerTheme = next;
    try {
      localStorage.setItem(STORAGE_THEME, next);
    } catch (_) {}
    syncButtons();
  }

  function applyLayout(layout) {
    const s = shell();
    if (!s) return;
    s.dataset.readerLayout = layout;
    try {
      localStorage.setItem(STORAGE_LAYOUT, layout);
    } catch (_) {}
    syncButtons();
  }

  function applyFont(size) {
    const s = shell();
    if (!s) return;
    const next = normalizeFont(size);
    s.dataset.readerFontSize = next;
    try {
      localStorage.setItem(STORAGE_FONT, next);
    } catch (_) {}
    syncButtons();
  }

  function applyLeading(level) {
    const s = shell();
    if (!s) return;
    const next = normalizeLeading(level);
    s.dataset.readerLeading = next;
    try {
      localStorage.setItem(STORAGE_LEADING, next);
    } catch (_) {}
    syncButtons();
  }

  document.querySelectorAll('[data-reader-theme]').forEach((btn) => {
    btn.addEventListener('click', () => {
      applyTheme(btn.getAttribute('data-reader-theme'));
    });
  });

  document.querySelectorAll('[data-reader-layout]').forEach((btn) => {
    btn.addEventListener('click', () => {
      applyLayout(btn.getAttribute('data-reader-layout'));
    });
  });

  document.querySelectorAll('[data-reader-font]').forEach((btn) => {
    btn.addEventListener('click', () => {
      applyFont(btn.getAttribute('data-reader-font'));
    });
  });

  document.querySelectorAll('[data-reader-leading]').forEach((btn) => {
    btn.addEventListener('click', () => {
      applyLeading(btn.getAttribute('data-reader-leading'));
    });
  });

  document.querySelectorAll('[data-reader-segments]').forEach((btn) => {
    btn.addEventListener('click', () => {
      applySegmentMode(btn.getAttribute('data-reader-segments'));
    });
  });

  (function initFromStorage() {
    const s = shell();
    if (!s) return;
    try {
      const theme = normalizeTheme(localStorage.getItem(STORAGE_THEME));
      s.dataset.readerTheme = theme;
      localStorage.setItem(STORAGE_THEME, theme);

      const font = normalizeFont(localStorage.getItem(STORAGE_FONT));
      s.dataset.readerFontSize = font;
      localStorage.setItem(STORAGE_FONT, font);

      const layout = localStorage.getItem(STORAGE_LAYOUT);
      if (layout === 'scroll' || layout === 'columns') {
        s.dataset.readerLayout = layout;
      }

      const leading = normalizeLeading(localStorage.getItem(STORAGE_LEADING));
      s.dataset.readerLeading = leading;
      localStorage.setItem(STORAGE_LEADING, leading);

      if (!localStorage.getItem(STORAGE_SEGMENTS_MIGRATION)) {
        const prev = localStorage.getItem(STORAGE_SEGMENTS);
        const migrated = prev === 'on' || prev === 'clause' ? 'clause' : 'para';
        localStorage.setItem(STORAGE_SEGMENTS, migrated);
        localStorage.setItem(STORAGE_SEGMENTS_MIGRATION, '1');
      }

      const segments = normalizeSegmentMode(localStorage.getItem(STORAGE_SEGMENTS));
      s.dataset.readerSegments = segments;
      localStorage.setItem(STORAGE_SEGMENTS, segments);
    } catch (_) {}
    syncButtons();
    applySegmentMode(s.dataset.readerSegments ?? 'para');
  })();
</script>
