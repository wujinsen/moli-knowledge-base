---
interface Props {
  href: string;
  name: string;
  kind: 'medicine' | 'dish' | 'costume' | 'custom' | 'artifact';
  subtype?: string;
  summary?: string;
  tags?: string[];
}

const { href, name, kind, subtype, summary, tags = [] } = Astro.props;

const kindLabel: Record<Props['kind'], string> = {
  medicine: '医药',
  dish: '饮食',
  costume: '服饰',
  custom: '民俗',
  artifact: '法宝',
};

const kindColor: Record<Props['kind'], string> = {
  medicine: 'bg-emerald-100 text-emerald-800',
  dish: 'bg-orange-100 text-orange-800',
  costume: 'bg-violet-100 text-violet-800',
  custom: 'bg-amber-100 text-amber-800',
  artifact: 'bg-sky-100 text-sky-800',
};
---

<a
  href={href}
  class="catalog-card block rounded-lg border p-4 transition hover:shadow-md sm:p-5"
  style="border-color: var(--line); background: var(--paper-2)"
>
  <div class="flex items-start justify-between gap-2">
    <h3 class="catalog-card-title">{name}</h3>
    <span class={`catalog-card-badge shrink-0 rounded px-2 py-0.5 ${kindColor[kind]}`}>
      {kindLabel[kind]}
    </span>
  </div>
  {subtype && <p class="catalog-card-meta mt-1.5">{subtype}</p>}
  {summary && <p class="catalog-card-summary mt-2.5 line-clamp-3">{summary}</p>}
  {
    tags.length > 0 && (
      <div class="mt-auto flex flex-wrap gap-1.5 pt-3">
        {tags.map((t) => (
          <span class="chip chip-foot text-xs">{t}</span>
        ))}
      </div>
    )
  }
</a>
