---
interface Props {
  slug: string;
  book: string;
  characters?: string[];
  locations?: string[];
  items?: string[];
  hasPlaces?: boolean;
  hasItems?: boolean;
  hasSilver?: boolean;
  hasPoems?: boolean;
  itemRefs?: { id: string; name: string }[];
  txRefs?: { id: string; summary: string; amount?: string }[];
  imageryRefs?: { id: string; title: string; hasInference?: boolean }[];
  characterIds?: Set<string>;
  readEdition?: string;
}

const {
  slug,
  characters = [],
  locations = [],
  items = [],
  hasPlaces = false,
  hasItems = false,
  hasSilver = false,
  hasPoems = false,
  itemRefs = [],
  txRefs = [],
  imageryRefs = [],
  characterIds = new Set<string>(),
  readEdition = '1',
} = Astro.props;

const show =
  (hasPlaces && locations.length > 0) ||
  (hasItems && itemRefs.length > 0) ||
  (hasSilver && txRefs.length > 0) ||
  (hasPoems && imageryRefs.length > 0) ||
  characters.length > 0;

if (!show) return null;

const itemNameById = new Map(itemRefs.map((r) => [r.id, r.name]));
---

<aside class="reader-chapter-links mt-4 rounded-lg p-4" data-pagefind-ignore>
  <p class="reader-chapter-links-title mb-3 font-medium">本回关联</p>
  <div class="reader-chapter-links-groups">
    {
      hasPlaces && locations.length > 0 && (
        <div class="reader-chapter-links-group">
          <span class="reader-chapter-links-label">地点</span>
          <div class="reader-chapter-links-tags">
            {locations.map((id) => (
              <a href={`/${slug}/l/${id}`} class="reader-chapter-links-tag" title={`查看地点：${id}`}>
                {id}
              </a>
            ))}
          </div>
        </div>
      )
    }
    {
      hasItems && items.length > 0 && (
        <div class="reader-chapter-links-group">
          <span class="reader-chapter-links-label">名物</span>
          <div class="reader-chapter-links-tags">
            {items.map((id) => (
              <a
                href={`/${slug}/i/${id}`}
                class="reader-chapter-links-tag"
                title={`查看名物：${itemNameById.get(id) ?? id}`}
              >
                {itemNameById.get(id) ?? id}
              </a>
            ))}
          </div>
        </div>
      )
    }
    {
      hasSilver && txRefs.length > 0 && (
        <div class="reader-chapter-links-group">
          <span class="reader-chapter-links-label">白银</span>
          <div class="reader-chapter-links-tags">
            {txRefs.map((tx) => (
              <a
                href={`/${slug}/read/${readEdition}/${tx.chapter}`}
                class="reader-chapter-links-tag"
                title={tx.summary}
              >
                {tx.amount ? `${tx.amount} · ${tx.summary}` : tx.summary}
              </a>
            ))}
          </div>
        </div>
      )
    }
    {
      hasPoems && imageryRefs.length > 0 && (
        <div class="reader-chapter-links-group">
          <span class="reader-chapter-links-label">诗词意象</span>
          <div class="reader-chapter-links-tags">
            {imageryRefs.map((im) => (
              <a
                href={`/${slug}/imagery/${im.id}`}
                class="reader-chapter-links-tag"
                title={im.hasInference ? `${im.title}（含推论边）` : im.title}
              >
                {im.title}
              </a>
            ))}
          </div>
        </div>
      )
    }
    {
      characters.length > 0 && (
        <div class="reader-chapter-links-group">
          <span class="reader-chapter-links-label">人物</span>
          <div class="reader-chapter-links-tags">
            {characters.map((id) =>
              characterIds.has(id) ? (
                <a href={`/${slug}/c/${id}`} class="reader-chapter-links-tag" title={`查看人物：${id}`}>
                  {id}
                </a>
              ) : (
                <span class="reader-chapter-links-plain">{id}</span>
              ),
            )}
          </div>
        </div>
      )
    }
  </div>
</aside>
