---
interface Props {
  href: string;
  name: string;
  type: string;
  category?: string;
  parent?: string;
  plaque?: string;
  summary?: string;
  tags?: string[];
}

const { href, name, type, category, parent, plaque, summary, tags = [] } = Astro.props;

const typeColor: Record<string, string> = {
  garden: 'bg-green-100 text-green-800',
  building: 'bg-sky-100 text-sky-800',
  location: 'bg-stone-100 text-stone-800',
  temple: 'bg-amber-100 text-amber-800',
  realm: 'bg-violet-100 text-violet-800',
};
---

<a
  href={href}
  class="block rounded-lg border border-stone-300 bg-white p-4 transition hover:shadow-md"
>
  <div class="flex items-center justify-between gap-2">
    <h3 class="text-lg font-bold text-stone-800">{name}</h3>
    <span class={`shrink-0 rounded px-2 py-0.5 text-xs ${typeColor[type] ?? 'bg-stone-100 text-stone-700'}`}>
      {category ?? type}
    </span>
  </div>
  {plaque && <p class="mt-1 text-xs text-stone-500">匾：{plaque}</p>}
  {parent && !plaque && <p class="mt-1 text-xs text-stone-500">属：{parent}</p>}
  {summary && <p class="mt-2 line-clamp-3 text-sm text-stone-600">{summary}</p>}
  {
    tags.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1">
        {tags.map((t) => (
          <span class="rounded bg-stone-100 px-1.5 py-0.5 text-xs text-stone-500">{t}</span>
        ))}
      </div>
    )
  }
</a>
