---
interface Props {
  href: string;
  name: string;
  type: string;
  category?: string;
  parent?: string;
  plaque?: string;
  summary?: string;
  tags?: string[];
}

const { href, name, type, category, parent, plaque, summary, tags = [] } = Astro.props;

const typeColor: Record<string, string> = {
  garden: 'bg-green-100 text-green-800',
  building: 'bg-sky-100 text-sky-800',
  location: 'bg-stone-100 text-stone-800',
  temple: 'bg-amber-100 text-amber-800',
  realm: 'bg-violet-100 text-violet-800',
};
---

<a
  href={href}
  class="catalog-card block rounded-lg border p-4 transition hover:shadow-md sm:p-5"
  style="border-color: var(--line); background: var(--paper-2)"
>
  <div class="flex items-start justify-between gap-2">
    <h3 class="catalog-card-title">{name}</h3>
    <span class={`catalog-card-badge shrink-0 rounded px-2 py-0.5 ${typeColor[type] ?? 'bg-stone-100 text-stone-700'}`}>
      {category ?? type}
    </span>
  </div>
  {plaque && <p class="catalog-card-meta mt-1.5">匾：{plaque}</p>}
  {parent && !plaque && <p class="catalog-card-meta mt-1.5">属：{parent}</p>}
  {summary && <p class="catalog-card-summary mt-2.5 line-clamp-3">{summary}</p>}
  {
    tags.length > 0 && (
      <div class="mt-auto flex flex-wrap gap-1.5 pt-3">
        {tags.map((t) => (
          <span class="chip chip-foot text-xs">{t}</span>
        ))}
      </div>
    )
  }
</a>
