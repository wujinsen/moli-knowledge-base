---
import '../styles/global.css';
import TopModuleNav from '../components/TopModuleNav.astro';
import ModuleContext from '../components/ModuleContext.astro';
import LangSwitch from '../components/LangSwitch';
import { themeFor, modulesFor, activeModule } from '../lib/books';

interface Props {
  title: string;
  bookSlug?: string;
  bookName?: string;
  features?: string[];
  readerWide?: boolean;
  moduleContext?: boolean;
}
const {
  title,
  bookSlug,
  bookName,
  features = [],
  readerWide = false,
  moduleContext = true,
} = Astro.props;
const theme = themeFor(bookSlug);
const navModules =
  bookSlug && bookName ? modulesFor(bookSlug, features).filter((m) => m.status === 'live') : [];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = path === '/';
const currentModule =
  bookSlug && bookName ? activeModule(path, bookSlug, modulesFor(bookSlug, features)) : undefined;
const showModuleContext = Boolean(
  moduleContext && bookSlug && bookName && currentModule && path !== `/${bookSlug}`,
);
---

<!doctype html>
<html lang="zh-CN" data-book={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · 古典小说知识库</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=Noto+Serif+SC:wght@400;500;600;700;900&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      try {
        var l = localStorage.getItem('kb-home-locale');
        if (l === 'en' || l === 'ja') document.documentElement.lang = l === 'ja' ? 'ja' : 'en';
      } catch (e) {}
    </script>
  </head>
  <body class="min-h-screen" data-page-title={title}>
    <header class="topbar sticky top-0 z-30">
      <div class="topbar-inner mx-auto max-w-6xl px-4">
        <nav class="flex items-center gap-3 py-2.5" aria-label="站点导航">
          {
            bookSlug && bookName ? (
              <>
                <a href="/" class="text-sm opacity-80 hover:opacity-100" data-i18n="nav.canon">典籍</a>
                <span class="opacity-40">·</span>
                <a href={`/${bookSlug}`} class="brand-link brand text-xl">
                  {bookName}
                </a>
                <div class="ml-auto flex items-center gap-2">
                  <LangSwitch client:load />
                  <a href="/search" class="rounded px-2.5 py-1 text-sm hover:bg-white/10" data-i18n="nav.search">
                    检索
                  </a>
                </div>
              </>
            ) : (
              <>
                <a href="/" class="brand-link brand text-xl" data-i18n={isHome ? 'siteTitle' : 'nav.canon'}>
                  古典名著知识库
                </a>
                <div class="ml-auto flex items-center gap-2">
                  <LangSwitch client:load />
                  <a href="/search" class="rounded px-2.5 py-1 text-sm hover:bg-white/10" data-i18n="nav.search">
                    检索
                  </a>
                </div>
              </>
            )
          }
        </nav>
        {
          bookSlug && navModules.length > 0 && (
            <TopModuleNav bookSlug={bookSlug} modules={navModules} path={path} />
          )
        }
      </div>
    </header>

    <div class:list={['page-below-nav', readerWide && 'page-below-nav--reader']}>
      <main
        class:list={[
          'site-main mx-auto py-6',
          readerWide ? 'reader-main w-full max-w-none' : 'max-w-6xl px-4 py-8',
        ]}
      >
        {
          showModuleContext && currentModule && bookName && bookSlug && (
            <ModuleContext module={currentModule} bookName={bookName} bookSlug={bookSlug}>
              <slot name="module-extra" />
            </ModuleContext>
          )
        }
        <slot />
      </main>

      <footer
        class:list={[
          'pb-10 pt-6 text-base font-medium leading-relaxed',
          readerWide ? 'w-full max-w-none' : 'mx-auto max-w-6xl px-4',
        ]}
        style="color: color-mix(in srgb, var(--ink) 58%, var(--ink-soft))"
      >
        <div class="rule-seal mb-4">
          <span class="brand text-base">墨</span>
        </div>
        <p data-i18n="footer">
          数据由 LLM 按 AGENTS.md 维护 · 原文只读真相源 · 事实与推论分层
        </p>
      </footer>
    </div>
  </body>
</html>
