---
import Base from '../layouts/Base.astro';
import Search from '../components/Search.astro';
---

<Base title="搜索">
  <div class="content-page">
  <h1 class="brand mb-2 text-3xl" style="color: var(--primary)" data-pagefind-ignore>站内检索</h1>
  <p class="mb-6 text-sm text-muted" data-pagefind-ignore>
    检索范围：已 ingest 的回目、人物 / 妖怪、主题页。原文随导入逐步纳入。
  </p>
  <div data-pagefind-ignore>
    <Search />
  </div>
  </div>
</Base>
