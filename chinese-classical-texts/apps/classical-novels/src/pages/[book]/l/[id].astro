---
import { getCollection, render } from 'astro:content';
import { getBooks } from '../../../lib/getBooks';
import Base from '../../../layouts/Base.astro';
import BackLink from '../../../components/BackLink.astro';
import { loadBookPlaces, typeLabel } from '../../../lib/places';
import { chaptersFromAppearIn, relatedItemsForPlace, milestoneEventsForPlace } from '../../../lib/crosslinks';
import { chapterLabel } from '../../../lib/events';

export async function getStaticPaths() {
  const books = await getBooks();
  const slugByBook = new Map(books.map((b) => [b.data.book, b.data.slug]));

  const paths: {
    params: { book: string; id: string };
    props: { slug: string; entry: Awaited<ReturnType<typeof loadBookPlaces>>[number]; features: string[] };
  }[] = [];

  for (const b of books.filter(
    (x) =>
      x.data.features.includes('places') ||
      x.data.features.includes('route') ||
      x.data.features.includes('town'),
  )) {
    const places = await loadBookPlaces(b.data.book);
    for (const entry of places) {
      paths.push({
        params: { book: slugByBook.get(b.data.book)!, id: entry.data.id },
        props: { slug: slugByBook.get(b.data.book)!, entry, features: b.data.features },
      });
    }
  }
  return paths;
}

const { slug, entry, features } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

// 取经路线地点回链取经路线；金瓶梅 map_zone → 市井地图；红楼 garden_zone → 大观园地图
const isRoute = features.includes('route') && !!d.layer;
const isTown = features.includes('town') && !!d.map_zone;
const isGarden = features.includes('garden') && !!d.garden_zone;
const isManor = features.includes('manor') && !!d.manor_zone;
const isCapital = features.includes('capital') && !!d.capital_zone;
const backHref = isRoute
  ? `/${slug}/route`
  : isTown
    ? `/${slug}/town`
    : isGarden
      ? `/${slug}/map`
      : isManor
        ? `/${slug}/manor`
        : isCapital
          ? `/${slug}/capital`
          : `/${slug}/places`;
const placesLabel =
  slug === 'jinpingmei' ? '西门府' : slug === 'honglou' ? '建筑图鉴' : '地点';
const backLabel = isRoute
  ? '取经路线'
  : isTown
    ? '市井地图'
    : isGarden
      ? '大观园地图'
      : isManor
        ? '宁荣两府地图'
        : isCapital
          ? '都外与王公地图'
          : placesLabel;

const relatedItems = await relatedItemsForPlace(d.book, d.id, d.occupants);
const chapterNums = chaptersFromAppearIn(d.appear_in);
const keyEvents = features.includes('saga')
  ? await milestoneEventsForPlace(d.book, d.id)
  : [];
---

<Base title={d.name} bookSlug={slug} bookName={d.book} features={features}>
  <BackLink href={backHref} label={backLabel} />
  <div
    class="content-page"
    data-pagefind-body
    data-pagefind-meta={`title:${d.name}`}
    data-pagefind-filter={`书:${d.book},类型:${typeLabel(d.type)}`}
  >
    <div class="mt-3 flex flex-wrap items-center gap-2">
      <h1 class="brand text-4xl" style="color: var(--primary)">{d.name}</h1>
      <span class="chip chip-md">{typeLabel(d.type)}</span>
      {d.category && <span class="chip chip-md">{d.category}</span>}
    </div>

    {d.aliases.length > 0 && (
      <p class="mt-2 text-sm">别名：{d.aliases.join('、')}</p>
    )}
    {d.summary && <p class="page-lead mt-2">{d.summary}</p>}

    {
      d.plaque && (
        <div class="entity-spec surface mt-4 p-4 sm:p-5">
          <div class="brand text-lg" style="color: var(--primary)">匾 · {d.plaque}</div>
          {
            d.couplet && (
              <div class="mt-1.5">
                联：{d.couplet.upper}；{d.couplet.lower}
              </div>
            )
          }
        </div>
      )
    }

    <div class="entity-spec surface mt-4 grid gap-2.5 p-4 sm:grid-cols-2 sm:p-5">
      {d.realm && <div>地理：{d.realm}（{d.layer === 'myth' ? '神话异界' : '凡间路线'}）</div>}
      {d.route_order != null && (
        <div>
          取经第 {d.route_order} 站 · <a class="hover:underline" style="color: var(--primary)" href={`/${slug}/route`}>路线图</a>
        </div>
      )}
      {d.map_zone && d.coord && (
        <div>
          {d.map_zone} · <a class="hover:underline" style="color: var(--primary)" href={`/${slug}/town`}>市井地图</a>
        </div>
      )}
      {d.garden_zone && d.coord && (
        <div>
          {d.garden_zone}
          {d.tour_order != null && ` · 游线第 ${d.tour_order} 站`} ·{' '}
          <a class="hover:underline" style="color: var(--primary)" href={`/${slug}/map`}>大观园地图</a>
        </div>
      )}
      {d.manor_zone && d.coord && (
        <div>
          {d.manor_zone} ·{' '}
          <a class="hover:underline" style="color: var(--primary)" href={`/${slug}/manor`}>宁荣两府地图</a>
        </div>
      )}
      {d.capital_zone && d.coord && (
        <div>
          {d.capital_zone} ·{' '}
          <a class="hover:underline" style="color: var(--primary)" href={`/${slug}/capital`}>都外与王公地图</a>
        </div>
      )}
      {d.parent && (
        <div>
          上级：<a class="hover:underline" style="color: var(--primary)" href={`/${slug}/l/${d.parent}`}>{d.parent}</a>
        </div>
      )}
      {d.first_appear && <div>首现：{d.first_appear}</div>}
      {d.occupants.length > 0 && <div>居住/关联：{d.occupants.join('、')}</div>}
      {d.plants.length > 0 && <div>植物：{d.plants.join('、')}</div>}
    </div>

    {
      d.features.length > 0 && (
        <ul class="mt-3 list-inside list-disc text-sm">
          {d.features.map((f) => (
            <li>{f}</li>
          ))}
        </ul>
      )
    }

    {
      d.nearby.length > 0 && (
        <div class="mt-6">
          <h2 class="section-title mb-2">邻近</h2>
          <div class="flex flex-wrap gap-2">
            {d.nearby.map((n) => (
              <a href={`/${slug}/l/${n}`} class="chip hover:underline">
                {n}
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      keyEvents.length > 0 && (
        <div class="mt-6">
          <h2 class="section-title mb-2">关键事件</h2>
          <ul class="space-y-2">
            {keyEvents.map((ev) => (
              <li class="surface px-3 py-2">
                <a class="hover:underline" style="color: var(--primary)" href={`/${slug}/e/${ev.id}`}>{ev.title}</a>
                <span class="ml-1 chip text-xs">{chapterLabel(ev.chapters)}</span>
                {ev.summary && <span class="ml-1 text-sm text-muted">· {ev.summary}</span>}
              </li>
            ))}
          </ul>
          <a href={`/${slug}/saga`} class="mt-2 inline-block text-sm hover:underline" style="color: var(--accent)">查看大事记 →</a>
        </div>
      )
    }

    {
      relatedItems.length > 0 && (
        <div class="mt-6">
          <h2 class="section-title mb-2">相关名物</h2>
          <div class="flex flex-wrap gap-2">
            {relatedItems.map((item) => (
              <a href={`/${slug}/i/${item.id}`} class="chip hover:underline">
                {item.name}
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      chapterNums.length > 0 && (
        <div class="mt-6">
          <h2 class="section-title mb-2">相关回目</h2>
          <div class="flex flex-wrap gap-2">
            {chapterNums.map((num) => (
              <a href={`/${slug}/read/${num}`} class="chip hover:underline">
                第{num}回
              </a>
            ))}
          </div>
        </div>
      )
    }

    <article class="prose-cn mt-6 max-w-none">
      <Content />
    </article>
  </div>
</Base>
