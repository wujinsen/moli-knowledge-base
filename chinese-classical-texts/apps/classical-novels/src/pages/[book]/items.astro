---
import { getBooks } from '../../lib/getBooks';
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import MaterialHubCard from '../../components/MaterialHubCard.astro';
import MaterialModuleNav from '../../components/MaterialModuleNav.astro';
import {
  hasMaterialFeature,
  materialCrossIndexHref,
  materialInferenceHref,
  materialInferenceLabel,
  materialModuleHref,
  materialModulesForBook,
  hubExtraTopics,
} from '../../lib/materialModules';
import { groupByKind, itemsIndexTitle, loadBookItems } from '../../lib/items';
import { getItemsCrossIndex } from '../../lib/itemsCrossIndex';

export async function getStaticPaths() {
  const books = await getBooks();
  return books
    .filter((b) => b.data.features.includes('items'))
    .map((b) => ({ params: { book: b.data.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const meta = book.data;
const items = await loadBookItems(meta.book);
const grouped = groupByKind(items);
const indexTitle = itemsIndexTitle(meta.book);
const isXiyouji = meta.book === '西游记';
const modules = materialModulesForBook(meta.slug, meta.features);
const crossIndex = getItemsCrossIndex(meta.slug);
const extraTopics = hubExtraTopics(meta.slug);
const hasDiet = hasMaterialFeature(meta.features, 'food') && meta.features.includes('diet');

function hubInference(m: (typeof modules)[0]) {
  if (m.key === 'food' && !hasDiet) return undefined;
  if (m.key !== 'food' && m.key !== 'medicine' && m.key !== 'costume' && m.key !== 'custom') return undefined;
  if (!hasMaterialFeature(meta.features, m.key)) return undefined;
  if (m.key === 'food' && !hasDiet) return undefined;
  const href = materialInferenceHref(meta.slug, m.key);
  const label = materialInferenceLabel(m.key);
  return href && label ? { href, label } : undefined;
}
---

<Base title={`${meta.book} · ${indexTitle}`} bookSlug={meta.slug} bookName={meta.book} features={meta.features}>
  <Breadcrumb
    slot="breadcrumb"
    items={[{ href: `/${meta.slug}`, label: meta.book }, { label: indexTitle }]}
  />
  <p slot="module-extra" class="text-sm text-muted">
    {
      isXiyouji
        ? `共 ${items.length} 条 · 章回 / 人物交叉检索`
        : `共 ${items.length} 条 · 选一模块进入，或走交叉索引汇总检索`
    }
  </p>

  <div class="content-page material-hub-page">
    <MaterialModuleNav bookSlug={meta.slug} features={meta.features} active="hub" />

    <div class="material-hub-grid">
      {
        modules.map((m) => {
          const inf = hubInference(m);
          return (
            <MaterialHubCard
              href={materialModuleHref(meta.slug, m.key)}
              glyph={m.glyph}
              title={m.title}
              desc={m.desc}
              count={grouped[m.kind].length}
              subHref={inf?.href}
              subLabel={inf?.label}
            />
          );
        })
      }
      {
        crossIndex && (
          <MaterialHubCard
            href={materialCrossIndexHref(meta.slug)}
            glyph="索"
            title="交叉索引"
            desc="章回 × 人物 × 地点 · 全物质汇总"
            count={crossIndex.entries.length}
            countLabel="条索引"
          />
        )
      }
    </div>

    {
      extraTopics.length > 0 && (
        <section class="surface material-hub-topics">
          <h2 class="section-title">跨类纵切</h2>
          <div class="material-hub-topics__chips">
            {
              extraTopics.map((t) => (
                <a href={`/${meta.slug}/topics/${t.slug}`} class="chip chip-md hover:underline">
                  {t.title}
                </a>
              ))
            }
          </div>
        </section>
      )
    }
  </div>
</Base>
