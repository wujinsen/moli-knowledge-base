---
import { getCollection } from 'astro:content';
import { getBooks } from '../../lib/getBooks';
import Base from '../../layouts/Base.astro';
import PlaceCard from '../../components/PlaceCard.astro';
import CatalogFoldBar from '../../components/CatalogFoldBar.astro';
import CatalogFoldSection from '../../components/CatalogFoldSection.astro';
import {
  gardenChildren,
  groupByCategory,
  loadBookPlaces,
  placeRootFor,
  sortedCategories,
} from '../../lib/places';

export async function getStaticPaths() {
  const books = await getBooks();
  return books
    .filter((b) => b.data.features.includes('places'))
    .map((b) => ({
      params: { book: b.data.slug },
      props: { book: b },
    }));
}

const { book } = Astro.props;
const meta = book.data;
const places = await loadBookPlaces(meta.book);
const grouped = groupByCategory(places);
const categories = sortedCategories(grouped);
const root = placeRootFor(meta.book);
const rootChildren = root ? gardenChildren(places, root.id) : [];
const rootEntry = root ? places.find((p) => p.data.id === root.id) : undefined;
const rootCount = rootChildren.length + (rootEntry ? 1 : 0);
const hasRootSection = Boolean(root && rootCount > 0);

const categorySections = categories
  .map((cat) => {
    const list = grouped.get(cat)!;
    const rest = root
      ? list.filter((p) => p.data.id !== root.id && p.data.parent !== root.id)
      : list;
    return { cat, rest };
  })
  .filter(({ rest }) => rest.length > 0);

const foldLabel = meta.book === '红楼梦' ? '建筑分组' : '地点分组';
---

<Base title={`${meta.book} · 建筑居所`} bookSlug={meta.slug} bookName={meta.book} features={meta.features}>
  <p slot="module-extra" class="mt-2 text-sm text-muted">
    {root?.blurb ?? '府邸、园林、亭榭堂馆'}（共 {places.length} 处）
    {
      meta.features.includes('town') && (
        <a href={`/${meta.slug}/town`} class="ml-2 hover:underline" style="color: var(--accent)">
          → 市井地图
        </a>
      )
    }
    {
      meta.features.includes('garden') && (
        <a href={`/${meta.slug}/map`} class="ml-2 hover:underline" style="color: var(--accent)">
          → 大观园地图
        </a>
      )
    }
    {
      meta.features.includes('manor') && (
        <a href={`/${meta.slug}/manor`} class="ml-2 hover:underline" style="color: var(--accent)">
          → 宁荣两府地图
        </a>
      )
    }
  </p>

  <div class="content-page catalog-fold-page">
    {(hasRootSection || categorySections.length > 0) && (
      <CatalogFoldBar label={foldLabel} />
    )}

    {
      hasRootSection && (
        <CatalogFoldSection id={root!.id} title={root!.title} count={rootCount}>
          <div class="grid items-stretch gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
            {rootEntry && (
              <PlaceCard
                href={`/${meta.slug}/l/${rootEntry.data.id}`}
                name={rootEntry.data.name}
                type={rootEntry.data.type}
                category={rootEntry.data.category}
                summary={rootEntry.data.summary}
                tags={rootEntry.data.tags}
              />
            )}
            {rootChildren.map((entry) => (
              <PlaceCard
                href={`/${meta.slug}/l/${entry.data.id}`}
                name={entry.data.name}
                type={entry.data.type}
                category={entry.data.category}
                plaque={entry.data.plaque}
                summary={entry.data.summary}
                tags={entry.data.tags}
              />
            ))}
          </div>
        </CatalogFoldSection>
      )
    }

    {
      categorySections.map(({ cat, rest }) => (
        <CatalogFoldSection id={cat} title={cat} count={rest.length}>
          <div class="grid items-stretch gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
            {rest.map((entry) => (
              <PlaceCard
                href={`/${meta.slug}/l/${entry.data.id}`}
                name={entry.data.name}
                type={entry.data.type}
                category={entry.data.category}
                parent={entry.data.parent}
                plaque={entry.data.plaque}
                summary={entry.data.summary}
                tags={entry.data.tags}
              />
            ))}
          </div>
        </CatalogFoldSection>
      ))
    }
  </div>
</Base>
