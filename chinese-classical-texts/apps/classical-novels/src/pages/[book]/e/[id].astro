---
import { getCollection, render } from 'astro:content';
import { getBooks } from '../../../lib/getBooks';
import Base from '../../../layouts/Base.astro';
import BackLink from '../../../components/BackLink.astro';
import {
  chapterLabel,
  displayTitle,
  eventSubtypeLabel,
  formatLiangAmount,
} from '../../../lib/events';
import { chainEventLinks, chainEventHref, silverEventHref } from '../../../lib/chain';
import { getChainIndex, txChipLabel } from '../../../lib/chainIndex';
import { graphFocusHref } from '../../../lib/sna';
import { readChapterPath } from '../../../lib/editions';
import jpmSna from '../../../data/jinpingmei.sna.json';

export async function getStaticPaths() {
  const books = await getBooks();
  const events = await getCollection('events');
  const paths: { params: { book: string; id: string }; props: { book: typeof books[0]; ev: typeof events[0] } }[] = [];
  for (const b of books) {
    const feats = b.data.features;
    const allowed = new Set<string>();
    if (feats.includes('nan')) allowed.add('tribulation');
    if (feats.includes('chain')) {
      allowed.add('financial');
      allowed.add('plot');
    }
    if (feats.includes('saga')) allowed.add('milestone');
    if (allowed.size === 0) continue;
    for (const ev of events.filter((e) => e.data.book === b.data.book)) {
      if (!allowed.has(ev.data.subtype)) continue;
      paths.push({
        params: { book: b.data.slug, id: ev.data.id },
        props: { book: b, ev },
      });
    }
  }
  return paths;
}

const { book, ev } = Astro.props;
const meta = book.data;
const d = ev.data;
const isNan = d.subtype === 'tribulation';
const isMilestone = d.subtype === 'milestone';
const isChain = d.subtype === 'financial' || d.subtype === 'plot';
const no = d.tribulation_no;
const chapterHref = (c: number) => readChapterPath(meta.slug, meta.book, c);
const backHref = isNan
  ? `/${meta.slug}/nan`
  : isMilestone
    ? `/${meta.slug}/saga`
    : `/${meta.slug}/chain`;
const backLabel = isNan ? '八十一难时间轴' : isMilestone ? '大事记' : '发家衰败链';
const prevLabel = isNan ? '← 上一难' : '← 上一节点';
const nextLabel = isNan ? '下一难 →' : '下一节点 →';
const amount = formatLiangAmount(d.amount_liang);
const subtype = eventSubtypeLabel(d.subtype, d.financial_kind);
const snaMeta = meta.slug === 'jinpingmei' ? (jpmSna as { hubs?: string[]; bangxian_hubs?: string[] }) : {};
const chainIndex = getChainIndex(meta.slug);
const moduleLinks = isChain
  ? chainEventLinks(d.characters, d.transaction_refs ?? [], {
      hubs: snaMeta.hubs ?? [],
      bangxianHubs: snaMeta.bangxian_hubs ?? [],
      features: meta.features,
    })
  : null;
const { Content } = await render(ev);
---

<Base title={`${meta.book} · ${d.title}`} bookSlug={meta.slug} bookName={meta.book} features={meta.features}>
  <div class="content-page event-detail">
  <BackLink href={backHref} label={backLabel} />

  <section class="surface mt-3 mb-6 px-6 py-7 sm:px-8">
    <div class="flex flex-wrap items-start gap-4">
      {
        isNan && no != null && (
          <span
            class="brand grid h-14 w-14 shrink-0 place-items-center rounded-xl text-2xl font-semibold text-white"
            style="background: linear-gradient(135deg, var(--primary), var(--primary-soft))"
          >
            {no}
          </span>
        )
      }
      <div class="min-w-0 flex-1">
        <div class="mb-2 flex flex-wrap gap-2">
          <span class="chip chip-md">{subtype}</span>
          {amount && <span class="chip chip-md">{amount}</span>}
        </div>
        <h1 class="brand text-3xl sm:text-4xl" style="color: var(--primary)">{displayTitle(d)}</h1>
        {
          d.aliases.length > 0 && isNan && (
            <p class="mt-1.5 text-base text-muted">难簿名：{d.title}</p>
          )
        }
        {d.summary && <p class="event-summary mt-3">{d.summary}</p>}
      </div>
    </div>

    <dl class="event-meta mt-6 grid gap-x-4 gap-y-3 sm:grid-cols-2">
      {
        d.chapters.length > 0 && (
          <>
            <dt>回目锚点</dt>
            <dd>
              {
                d.chapters.map((c) => (
                  <a
                    href={chapterHref(c)}
                    class="event-link mr-2 hover:underline"
                  >
                    第{c}回
                  </a>
                ))
              }
              <span class="ml-1 event-meta-muted">（{chapterLabel(d.chapters)}）</span>
            </dd>
          </>
        )
      }
      {
        d.characters.length > 0 && (
          <>
            <dt>人物</dt>
            <dd>
              {
                d.characters.map((c) => (
                  <a href={`/${meta.slug}/c/${c}`} class="event-link mr-2 hover:underline">
                    {c}
                  </a>
                ))
              }
            </dd>
          </>
        )
      }
      {
        d.monsters.length > 0 && (
          <>
            <dt>妖魔</dt>
            <dd>{d.monsters.join(' · ')}</dd>
          </>
        )
      }
      {
        d.locations.length > 0 && (
          <>
            <dt>地点</dt>
            <dd>
              {
                d.locations.map((l) => (
                  <a href={`/${meta.slug}/l/${l}`} class="event-link mr-2 hover:underline">
                    {l}
                  </a>
                ))
              }
            </dd>
          </>
        )
      }
      {
        (d.map_route?.length ?? 0) > 0 && (
          <>
            <dt>途经路线</dt>
            <dd>
              {
                d.map_route!.map((l, i) => (
                  <>
                    {i > 0 && <span class="event-meta-muted mx-0.5">→</span>}
                    <a href={`/${meta.slug}/l/${l}`} class="event-link hover:underline">{l}</a>
                  </>
                ))
              }
            </dd>
          </>
        )
      }
      {
        d.artifacts.length > 0 && (
          <>
            <dt>法宝</dt>
            <dd>{d.artifacts.join(' · ')}</dd>
          </>
        )
      }
      {
        d.transaction_refs.length > 0 && (
          <>
            <dt>关联交易</dt>
            <dd>
              {
                d.transaction_refs.map((tid) => {
                  const chip = chainIndex?.tx_chips[tid];
                  return (
                    <a href={`/${meta.slug}/silver#${tid}`} class="event-link mr-2 hover:underline" title={chip?.summary ?? tid}>
                      {chip ? txChipLabel(chip, tid) : tid}
                    </a>
                  );
                })
              }
            </dd>
          </>
        )
      }
    </dl>

    <div class="mt-6 flex flex-wrap gap-3">
      {d.prev && (
        <a href={`/${meta.slug}/e/${d.prev}`} class="btn btn-ghost event-nav">{prevLabel}</a>
      )}
      {d.next && (
        <a href={`/${meta.slug}/e/${d.next}`} class="btn btn-ghost event-nav">{nextLabel}</a>
      )}
      {isChain && (
        <a href={chainEventHref(meta.slug, d.id)} class="btn btn-ghost">时间轴定位</a>
      )}
      {isMilestone && (
        <a href={`/${meta.slug}/saga#saga-${d.id}`} class="btn btn-ghost">大事记定位</a>
      )}
      {(d.map_route?.length ?? 0) > 0 && meta.features.includes('town') && (
        <a href={`/${meta.slug}/town?route=${d.id}`} class="btn btn-ghost">在市井地图看路线 →</a>
      )}
    </div>

    {
      isMilestone && meta.features.includes('graph') && d.characters.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2 text-xs">
          <span class="chip">模块联动</span>
          {d.characters.slice(0, 4).map((c) => (
            <a href={graphFocusHref(meta.slug, c)} class="chip hover:opacity-80" style="color:var(--accent)">
              图谱 · {c}
            </a>
          ))}
        </div>
      )
    }

    {
      moduleLinks && (moduleLinks.hasSilver || moduleLinks.hasSna || moduleLinks.graphFocus) && (
        <div class="mt-4 flex flex-wrap gap-2 text-xs">
          <span class="chip">模块联动</span>
          {
            moduleLinks.hasSilver && (
              <a href={silverEventHref(meta.slug, d.id)} class="chip hover:opacity-80" style="color:var(--accent)">
                白银流 · {d.transaction_refs.length} 笔
              </a>
            )
          }
          {
            moduleLinks.graphFocus && meta.features.includes('graph') && (
              <a href={graphFocusHref(meta.slug, moduleLinks.graphFocus)} class="chip hover:opacity-80" style="color:var(--accent)">
                图谱 · {moduleLinks.graphFocus}
              </a>
            )
          }
          {
            moduleLinks.hasSna && moduleLinks.graphFocus && (
              <a href={`/${meta.slug}/sna?focus=${encodeURIComponent(moduleLinks.graphFocus)}`} class="chip hover:opacity-80" style="color:var(--accent)">
                SNA
              </a>
            )
          }
        </div>
      )
    }
  </section>

  {
    d.scoped_relations.length > 0 && (
      <section class="surface mt-4 px-6 py-5 sm:px-8">
        <h2 class="mb-1 font-bold" style="color: var(--primary)">情境边 · 本节临时关系</h2>
        <p class="mb-3 text-sm text-muted">
          仅在本情节内成立（变身 / 伪装 / 化身），不进入稳定关系图谱。
        </p>
        <ul class="space-y-1.5 text-sm">
          {d.scoped_relations.map((r) => (
            <li class="flex flex-wrap items-center gap-1.5">
              <span class="font-bold" style="color: var(--accent)">{r.subject}</span>
              <span class="scoped-pred">{r.predicate}</span>
              <span style="color: var(--ink)">{r.object}</span>
              {r.ephemeral && <span class="chip chip-mini">临时</span>}
              {r.chapter && <span class="text-xs text-muted">（第{r.chapter}回）</span>}
            </li>
          ))}
        </ul>
        {meta.features.includes('quanshi') && (
          <a href={`/${meta.slug}/quanshi`} class="mt-3 inline-block text-sm hover:underline text-muted">
            查看全部情境边 →
          </a>
        )}
      </section>
    )
  }

  {
    d.variants && d.variants.length > 0 && (
      <section class="surface mt-4 px-6 py-5 sm:px-8">
        <h2 class="mb-1 font-bold" style="color: var(--primary)">版本异文 · 脂本探佚 vs 程高本</h2>
        <p class="mb-3 text-sm text-muted">
          《红楼梦》后四十回为程高本续补，与脂批所示曹雪芹原拟结局多有出入；下列并置两说，均注出处，不以一说为定论。
        </p>
        {d.contradicts && d.contradicts.length > 0 && (
          <div class="mb-3 flex flex-wrap gap-1.5">
            {d.contradicts.map((c) => (
              <span class="chip" style="color: var(--seal)">⚠ 版本争议 · {c}</span>
            ))}
          </div>
        )}
        <div class="grid gap-3 sm:grid-cols-2">
          {d.variants.map((v) => (
            <article
              class="rounded-lg p-4"
              style="border: 1px solid color-mix(in srgb, var(--primary) 14%, transparent)"
            >
              <span class="chip chip-md">{v.edition}</span>
              <p class="mt-2 leading-relaxed" style="color: var(--ink)">{v.claim}</p>
              {v.source && <p class="mt-2 text-xs text-muted">出处：{v.source}</p>}
            </article>
          ))}
        </div>
      </section>
    )
  }

  <div class="prose-cn event-prose surface mt-4 px-6 py-5 sm:px-8">
    <Content />
  </div>

  </div>

</Base>
