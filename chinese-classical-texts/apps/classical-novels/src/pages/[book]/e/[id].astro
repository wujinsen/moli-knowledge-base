---
import { getCollection, render } from 'astro:content';
import { getBooks } from '../../../lib/getBooks';
import Base from '../../../layouts/Base.astro';
import {
  chapterLabel,
  displayTitle,
  eventSubtypeLabel,
  formatLiangAmount,
} from '../../../lib/events';

export async function getStaticPaths() {
  const books = await getBooks();
  const events = await getCollection('events');
  const paths: { params: { book: string; id: string }; props: { book: typeof books[0]; ev: typeof events[0] } }[] = [];
  for (const b of books) {
    const feats = b.data.features;
    if (!feats.includes('nan') && !feats.includes('chain')) continue;
    for (const ev of events.filter((e) => e.data.book === b.data.book)) {
      if (feats.includes('chain') && !['financial', 'plot'].includes(ev.data.subtype)) continue;
      if (feats.includes('nan') && !feats.includes('chain') && ev.data.subtype !== 'tribulation') continue;
      paths.push({
        params: { book: b.data.slug, id: ev.data.id },
        props: { book: b, ev },
      });
    }
  }
  return paths;
}

const { book, ev } = Astro.props;
const meta = book.data;
const d = ev.data;
const isChain = meta.features.includes('chain');
const isNan = d.subtype === 'tribulation';
const no = d.tribulation_no;
const readEdition = meta.slug === 'jinpingmei' ? 'cihua' : '1';
const backHref = isChain ? `/${meta.slug}/chain` : `/${meta.slug}/nan`;
const backLabel = isChain ? '← 发家衰败链' : '← 八十一难时间轴';
const prevLabel = isNan ? '← 上一难' : '← 上一节点';
const nextLabel = isNan ? '下一难 →' : '下一节点 →';
const amount = formatLiangAmount(d.amount_liang);
const subtype = eventSubtypeLabel(d.subtype, d.financial_kind);
const { Content } = await render(ev);
---

<Base title={`${meta.book} · ${d.title}`} bookSlug={meta.slug} bookName={meta.book} features={meta.features}>
  <a href={backHref} class="text-sm hover:underline" style="color: var(--ink-soft)">{backLabel}</a>

  <section class="surface mt-3 mb-6 px-6 py-7 sm:px-8">
    <div class="flex flex-wrap items-start gap-4">
      {
        isNan && no != null && (
          <span
            class="brand grid h-14 w-14 shrink-0 place-items-center rounded-xl text-2xl text-white"
            style="background: linear-gradient(135deg, var(--primary), var(--primary-soft))"
          >
            {no}
          </span>
        )
      }
      <div>
        <div class="mb-2 flex flex-wrap gap-2">
          <span class="chip">{subtype}</span>
          {amount && <span class="chip">{amount}</span>}
        </div>
        <h1 class="brand text-3xl sm:text-4xl" style="color: var(--primary)">{displayTitle(d)}</h1>
        {
          d.aliases.length > 0 && isNan && (
            <p class="mt-1 text-sm" style="color: var(--ink-soft)">难簿名：{d.title}</p>
          )
        }
        {d.summary && <p class="mt-3 leading-relaxed" style="color: var(--ink)">{d.summary}</p>}
      </div>
    </div>

    <dl class="mt-6 grid gap-3 text-sm sm:grid-cols-2">
      {
        d.chapters.length > 0 && (
          <>
            <dt style="color: var(--ink-soft)">回目锚点</dt>
            <dd>
              {
                d.chapters.map((c) => (
                  <a
                    href={`/${meta.slug}/read/${readEdition}/${c}`}
                    class="mr-2 hover:underline"
                    style="color: var(--accent)"
                  >
                    第{c}回
                  </a>
                ))
              }
              <span class="ml-1" style="color: var(--ink-soft)">（{chapterLabel(d.chapters)}）</span>
            </dd>
          </>
        )
      }
      {
        d.characters.length > 0 && (
          <>
            <dt style="color: var(--ink-soft)">人物</dt>
            <dd>
              {
                d.characters.map((c) => (
                  <a href={`/${meta.slug}/c/${c}`} class="mr-2 hover:underline" style="color: var(--accent)">
                    {c}
                  </a>
                ))
              }
            </dd>
          </>
        )
      }
      {
        d.monsters.length > 0 && (
          <>
            <dt style="color: var(--ink-soft)">妖魔</dt>
            <dd>{d.monsters.join(' · ')}</dd>
          </>
        )
      }
      {
        d.locations.length > 0 && (
          <>
            <dt style="color: var(--ink-soft)">地点</dt>
            <dd>
              {
                d.locations.map((l) => (
                  <a href={`/${meta.slug}/l/${l}`} class="mr-2 hover:underline" style="color: var(--accent)">
                    {l}
                  </a>
                ))
              }
            </dd>
          </>
        )
      }
      {
        d.artifacts.length > 0 && (
          <>
            <dt style="color: var(--ink-soft)">法宝</dt>
            <dd>{d.artifacts.join(' · ')}</dd>
          </>
        )
      }
      {
        d.transaction_refs.length > 0 && (
          <>
            <dt style="color: var(--ink-soft)">关联交易</dt>
            <dd>
              {
                d.transaction_refs.map((tid) => (
                  <a href={`/${meta.slug}/silver#${tid}`} class="mr-2 hover:underline" style="color: var(--accent)">
                    {tid}
                  </a>
                ))
              }
            </dd>
          </>
        )
      }
    </dl>

    <div class="mt-6 flex flex-wrap gap-4 text-sm">
      {d.prev && (
        <a href={`/${meta.slug}/e/${d.prev}`} class="btn btn-ghost">{prevLabel}</a>
      )}
      {d.next && (
        <a href={`/${meta.slug}/e/${d.next}`} class="btn btn-ghost">{nextLabel}</a>
      )}
    </div>
  </section>

  <div class="prose-cn surface mt-4 px-6 py-5 text-sm leading-relaxed sm:px-8" style="color: var(--ink-soft)">
    <Content />
  </div>
</Base>
