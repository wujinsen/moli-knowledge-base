---
import { getCollection } from 'astro:content';
import { getBooks } from '../../lib/getBooks';
import Base from '../../layouts/Base.astro';
import JpmModuleNav from '../../components/JpmModuleNav.astro';
import SilverDashboard from '../../components/SilverDashboard.tsx';
import { formatLiang } from '../../lib/currency';
import { amountDisplay } from '../../lib/transactions';
import type { SilverData } from '../../lib/silver';
import jpmSilver from '../../data/jinpingmei.silver.json';

export async function getStaticPaths() {
  const books = await getBooks();
  return books
    .filter((b) => b.data.features.includes('silver'))
    .map((b) => ({ params: { book: b.data.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const meta = book.data;
const txs = (await getCollection('transactions'))
  .filter((t) => t.data.book === meta.book)
  .sort((a, b) => a.data.chapter - b.data.chapter);

const silverBySlug: Record<string, SilverData> = {
  jinpingmei: jpmSilver as SilverData,
};

const silverData = silverBySlug[meta.slug];
const totalLiang = silverData?.total_liang ?? txs.reduce((s, t) => s + (t.data.amount_normalized ?? 0), 0);

const txRows = txs.map((t) => ({
  id: t.data.id,
  chapter: t.data.chapter,
  subtype: t.data.subtype,
  amount: amountDisplay(t.data),
  parties: [t.data.buyer, t.data.seller, t.data.payee].filter(Boolean).join(' · '),
  summary: t.data.summary ?? '—',
  disputed: t.data.conversion_disputed ?? false,
  href: `/${meta.slug}/read/cihua/${t.data.chapter}`,
}));

const finEvents = (await getCollection('events'))
  .filter((e) => e.data.book === meta.book && e.data.subtype === 'financial')
  .sort((a, b) => (a.data.chapters[0] ?? 0) - (b.data.chapters[0] ?? 0));
---

<Base title={`${meta.book} · 白银流`} bookSlug={meta.slug} bookName={meta.book} features={meta.features}>
  <a href={`/${meta.slug}`} class="text-sm hover:underline" style="color: var(--ink-soft)">← {meta.book}</a>

  <section class="surface relative mt-3 mb-8 overflow-hidden px-6 py-7 sm:px-8">
    <div class="flex items-start gap-4">
      <span class="glyph" style="width:3.6rem;height:3.6rem;font-size:1.9rem">银</span>
      <div>
        <h1 class="brand text-4xl" style="color: var(--primary)">物价 · 白银流</h1>
        <p class="mt-2 text-sm" style="color: var(--ink-soft)">
          交易记录 · 银两换算 · 资金池桑基图 · {txs.length} 笔
          {silverData && ` · 构建期 JSON ${silverData.generated}`}
        </p>
      </div>
    </div>
    <p class="mt-5 max-w-2xl leading-relaxed text-sm" style="color: var(--ink)">
      以「两银」为统一口径归一化词话本中的银、钱、贯、文；每条交易可溯源至章回原文。
      晚明「1000 文 ≈ 1 两」为简化换算，存疑处已标注。运行
      <code class="mx-1 rounded px-1.5 py-0.5 text-xs" style="background: var(--base)">python scripts/build_silver.py 金瓶梅</code>
      重建桑基数据。
    </p>
  </section>

  {meta.slug === 'jinpingmei' && <JpmModuleNav bookSlug={meta.slug} features={meta.features} current="silver" />}

  {
    txs.length === 0 || !silverData ? (
      <div class="surface p-8 text-center" style="color: var(--ink-soft)">
        {txs.length === 0 ? (
          <>
            尚无交易记录，请向 <code>src/content/transactions/{meta.book}/</code> 录入数据。
          </>
        ) : (
          <>缺少 <code>src/data/{meta.slug}.silver.json</code>，请运行 build_silver.py。</>
        )}
      </div>
    ) : (
      <>
        <h2 class="section-title mb-4 text-lg">白银流向</h2>
        <div class="surface mb-10 p-4 sm:p-6">
          <SilverDashboard data={silverData} bookSlug={meta.slug} txRows={txRows} client:only="react" />
        </div>

        <h2 class="section-title mb-4 text-lg">交易清单</h2>
        <div class="mb-6 overflow-x-auto">
          <table class="w-full min-w-[640px] border-collapse text-sm">
            <thead>
              <tr style="border-bottom: 1.5px solid var(--line); color: var(--ink-soft)">
                <th class="px-3 py-2 text-left font-normal">回</th>
                <th class="px-3 py-2 text-left font-normal">类型</th>
                <th class="px-3 py-2 text-left font-normal">金额</th>
                <th class="px-3 py-2 text-left font-normal">当事人</th>
                <th class="px-3 py-2 text-left font-normal">摘要</th>
              </tr>
            </thead>
            <tbody>
              {
                txRows.map((r) => (
                  <tr id={r.id} style="border-bottom: 1px solid var(--line)">
                    <td class="px-3 py-2.5">
                      <a href={r.href} class="hover:underline" style="color: var(--accent)">{r.chapter}</a>
                    </td>
                    <td class="px-3 py-2.5">{r.subtype}</td>
                    <td class="px-3 py-2.5 whitespace-nowrap">
                      {r.amount}
                      {r.disputed && (
                        <span class="chip ml-1 text-xs" title="换算或金额存疑">存疑</span>
                      )}
                    </td>
                    <td class="px-3 py-2.5" style="color: var(--ink-soft)">{r.parties || '—'}</td>
                    <td class="px-3 py-2.5 max-w-xs truncate" style="color: var(--ink-soft)">{r.summary}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <div class="surface p-4 text-sm" style="color: var(--ink-soft)">
          <span class="chip">合计（标准化）</span>
          <strong style="color: var(--primary)">{formatLiang(totalLiang)}</strong>
          <span class="ml-2">· 资金池：西门庆府 → 妻妾奴婢 / 经营投资 / 政商贿赂 / 帮闲圈 等</span>
          {' · '}
          <a href={`/${meta.slug}/chain`} class="hover:underline" style="color: var(--accent)">发家衰败链</a>
          {' · '}
          <a href={`/${meta.slug}/topics/药铺与放债链`} class="hover:underline" style="color: var(--accent)">药铺与放债链</a>
        </div>

        {
          finEvents.length > 0 && (
            <>
              <h2 class="section-title mb-4 mt-10 text-lg">
                经济事件链
                <a href={`/${meta.slug}/chain`} class="ml-2 text-sm font-normal hover:underline" style="color: var(--accent)">
                  专题轨 →
                </a>
              </h2>
              <div class="grid gap-3 sm:grid-cols-2">
                {
                  finEvents.map((e) => (
                    <div class="surface p-4 text-sm">
                      <div class="mb-1 flex flex-wrap items-center gap-2">
                        <span class="chip text-xs">{e.data.financial_kind ?? '经济'}</span>
                        {e.data.amount_liang != null && (
                          <span style="color: var(--primary)">{formatLiang(e.data.amount_liang)}</span>
                        )}
                      </div>
                      <p class="font-medium" style="color: var(--ink)">{e.data.title}</p>
                      <p class="mt-1" style="color: var(--ink-soft)">{e.data.summary}</p>
                      <p class="mt-2 text-xs">
                        第 {e.data.chapters.join('、')} 回
                        {e.data.transaction_refs.length > 0 && (
                          <span>
                            {' · '}
                            {e.data.transaction_refs.map((tid, i) => (
                              <>
                                {i > 0 && ' · '}
                                <a href={`#${tid}`} class="hover:underline" style="color: var(--accent)">{tid}</a>
                              </>
                            ))}
                          </span>
                        )}
                      </p>
                    </div>
                  ))
                }
              </div>
            </>
          )
        }
      </>
    )
  }
</Base>

<script>
  /** 静态页 hash 定位：#jpm-tx-001 → 通知 React 仪表盘 */
  const hash = window.location.hash.replace('#', '');
  if (hash && hash.startsWith('jpm-tx')) {
    window.dispatchEvent(new CustomEvent('silver-highlight', { detail: hash }));
  }
  window.addEventListener('hashchange', () => {
    const id = window.location.hash.replace('#', '');
    if (id) window.dispatchEvent(new CustomEvent('silver-highlight', { detail: id }));
  });
</script>
