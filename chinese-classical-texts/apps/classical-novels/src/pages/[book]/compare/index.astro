---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import {
  COMPARE_PAIR_SLUGS,
  COMPARE_PAIRS,
  compareChapterPath,
  defaultComparePair,
  editionLabel,
} from '../../../lib/editions';
import { variantCountByChapter } from '../../../lib/variants';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books
    .filter((b) => b.data.features.includes('compare'))
    .map((b) => ({ params: { book: b.data.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const meta = book.data;
const pairSlug = defaultComparePair();
const pair = COMPARE_PAIRS[pairSlug];
const variantMap = await variantCountByChapter(meta.book);

const chapters = Array.from({ length: meta.chapter_count }, (_, i) => i + 1);
const jumpMarks = [1, 10, 20, 30, 50, 80, 100].filter((n) => n <= meta.chapter_count);
---

<Base title={`${meta.book} · 版本对勘`} bookSlug={meta.slug} bookName={meta.book} features={meta.features}>
  <a href={`/${meta.slug}`} class="text-sm hover:underline" style="color: var(--ink-soft)">← {meta.book}</a>

  <section class="surface relative mt-3 mb-8 overflow-hidden px-6 py-7 sm:px-8">
    <div class="flex items-start gap-4">
      <span class="glyph" style="width:3.6rem;height:3.6rem;font-size:1.9rem">勘</span>
      <div>
        <h1 class="brand text-4xl" style="color: var(--primary)">版本对勘</h1>
        <p class="mt-2 text-sm" style="color: var(--ink-soft)">
          词话 · 崇祯 · 竹坡三版本双栏并排 · {variantMap.size} 回已标异文锚点
        </p>
      </div>
    </div>
    <p class="mt-5 max-w-2xl text-sm leading-relaxed" style="color: var(--ink)">
      默认对勘 <strong>{pair.label}</strong>；可选版本组合见下方。已录入异文的回目标「异文」徽章。
    </p>
    <nav class="mt-4 flex flex-wrap gap-2 text-sm">
      {
        COMPARE_PAIR_SLUGS.map((slug) => (
          <a
            href={`/${meta.slug}/compare/${slug}/1`}
            class:list={['chip', slug === pairSlug && 'ring-1 ring-[var(--accent)]']}
          >
            {COMPARE_PAIRS[slug].label}
          </a>
        ))
      }
    </nav>
  </section>

  <div class="mb-4 flex flex-wrap items-center gap-2 text-sm" style="color: var(--ink-soft)">
    <span>跳至回目：</span>
    {
      jumpMarks.map((n) => (
        <a href={`#ch-${n}`} class="chip">{n}</a>
      ))
    }
  </div>

  <div class="surface overflow-hidden">
    <table class="w-full border-collapse text-sm">
      <thead>
        <tr style="border-bottom: 1.5px solid var(--line); color: var(--ink-soft)">
          <th class="px-4 py-2.5 text-left font-normal w-16">回</th>
          <th class="px-4 py-2.5 text-left font-normal">对勘</th>
          <th class="px-4 py-2.5 text-left font-normal w-24">异文</th>
        </tr>
      </thead>
      <tbody>
        {
          chapters.map((n) => {
            const vc = variantMap.get(n) ?? 0;
            return (
              <tr id={`ch-${n}`} style="border-bottom: 1px solid var(--line)">
                <td class="px-4 py-2 tabular-nums">{n}</td>
                <td class="px-4 py-2">
                  <a
                    href={compareChapterPath(meta.slug, pairSlug, n)}
                    class="hover:underline"
                    style="color: var(--accent)"
                  >
                    第 {n} 回 · {editionLabel(pair.left)} / {editionLabel(pair.right)}
                  </a>
                </td>
                <td class="px-4 py-2">
                  {vc > 0 ? (
                    <span class="chip text-xs">{vc} 处</span>
                  ) : (
                    <span style="color: var(--ink-soft)">—</span>
                  )}
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</Base>
