---
import { getCollection } from 'astro:content';
import { getBooks } from '../../../lib/getBooks';
import Base from '../../../layouts/Base.astro';
import BackLink from '../../../components/BackLink.astro';
import JpmModuleNav from '../../../components/JpmModuleNav.astro';
import CompareIndex from '../../../components/CompareIndex.tsx';
import {
  comparePairSlugs,
  comparePairsFor,
  compareChapterPath,
  defaultComparePair,
} from '../../../lib/editions';
import { getCompareIndex } from '../../../lib/compareIndex';

export async function getStaticPaths() {
  const books = await getBooks();
  return books
    .filter((b) => b.data.features.includes('compare'))
    .map((b) => ({ params: { book: b.data.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const meta = book.data;
const pairSlug = defaultComparePair(meta.slug);
const pair = comparePairsFor(meta.slug)[pairSlug];
const compareIntro =
  meta.slug === 'xiyouji'
    ? '世德堂 · 通本双版本双栏并排'
    : meta.slug === 'honglou'
      ? '脂砚斋本 · 程高本双栏并排（前 80 回；81–120 续书议题 + 单栏程高）'
      : '词话 · 崇祯 · 竹坡三版本双栏并排';
const compareIndex = getCompareIndex(meta.slug);

const jumpMarks = [1, 10, 20, 30, 50, 80, 100].filter((n) => n <= meta.chapter_count);
---

<Base title={`${meta.book} · 版本对勘`} bookSlug={meta.slug} bookName={meta.book} features={meta.features}>
  <BackLink href={`/${meta.slug}`} label={meta.book} />

  <div class="content-page">
  <section class="surface relative mt-3 mb-8 overflow-hidden px-6 py-7 sm:px-8">
    <div class="flex items-start gap-4">
      <span class="glyph" style="width:3.6rem;height:3.6rem;font-size:1.9rem">勘</span>
      <div>
        <h1 class="brand text-4xl" style="color: var(--primary)">版本对勘</h1>
        <p class="mt-2 text-sm text-muted">
          {compareIntro}
          {
            compareIndex
              ? ` · ${compareIndex.variant_total} 处异文锚点 · ${compareIndex.chapter_count_with_variants} 回已标`
              : ''
          }
        </p>
      </div>
    </div>
    <p class="mt-5 max-w-2xl text-sm leading-relaxed" style="color: var(--ink)">
      {
        meta.slug === 'honglou' ? (
          <>
            默认对勘 <strong>{pair.label}</strong>；前 80 回双栏同步滚动（左栏含脂批），81 回起为程高续书单栏 + 版本议题锚点。
          </>
        ) : (
          <>
            默认对勘 <strong>{pair.label}</strong>；J3 支持三对组合切换、<strong>仅异文回</strong>筛选、双栏同步滚动与正文高亮。
          </>
        )
      }
    </p>
    <nav class="mt-4 flex flex-wrap gap-2 text-sm">
      {
        meta.features.includes('graph') && (
          <a href={`/${meta.slug}/graph`} class="chip" style="color: var(--accent)">
            关系图谱 · 版本议题
          </a>
        )
      }
      {
        meta.slug === 'jinpingmei' && (
          <a href={`/${meta.slug}/topics/版本对勘样本`} class="chip" style="color: var(--primary)">
            版本对勘样本 →
          </a>
        )
      }
      {
        meta.slug === 'xiyouji' && meta.features.includes('kaozheng') && (
          <a href={`/${meta.slug}/kaozheng`} class="chip" style="color: var(--accent)">
            考证台 · 版本学
          </a>
        )
      }
      {
        meta.slug === 'honglou' && (
          <>
            <a href={`/${meta.slug}/kaozheng`} class="chip" style="color: var(--accent)">
              考证台 · 版本学
            </a>
            <a href={`/${meta.slug}/topics/版本异文与探佚`} class="chip" style="color: var(--primary)">
              版本异文与探佚 →
            </a>
            <a href={`/${meta.slug}/graph`} class="chip" style="color: var(--accent)">
              关系图谱 · 矛盾边
            </a>
          </>
        )
      }
    </nav>
  </section>

  {meta.slug === 'jinpingmei' && <JpmModuleNav bookSlug={meta.slug} features={meta.features} current="compare" />}

  {
    compareIndex ? (
      <>
        <div class="mb-4 flex flex-wrap items-center gap-2 text-sm text-muted">
          <span>跳至回目：</span>
          {
            jumpMarks.map((n) => (
              <a href={`#ch-${n}`} class="chip">{n}</a>
            ))
          }
        </div>
        <CompareIndex
          index={compareIndex}
          bookSlug={meta.slug}
          chapterCount={meta.chapter_count}
          initialPair={pairSlug}
          client:load
        />
      </>
    ) : (
      <p class="text-sm text-muted">对勘索引尚未生成，请运行 build_compare.py --write</p>
    )
  }
  </div>
</Base>
