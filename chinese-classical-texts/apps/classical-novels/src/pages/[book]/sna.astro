---
import { getBooks } from '../../lib/getBooks';
import Base from '../../layouts/Base.astro';
import BackLink from '../../components/BackLink.astro';
import JpmModuleNav from '../../components/JpmModuleNav.astro';
import SnaDashboard from '../../components/SnaDashboard.tsx';
import type { SnaData } from '../../lib/sna';
import jpmSna from '../../data/jinpingmei.sna.json';

export async function getStaticPaths() {
  const books = await getBooks();
  return books
    .filter((b) => b.data.features.includes('sna'))
    .map((b) => ({ params: { book: b.data.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const meta = book.data;

const snaBySlug: Record<string, SnaData> = {
  jinpingmei: jpmSna as SnaData,
};

const data = snaBySlug[meta.slug] ?? { book: meta.book, metrics: [], hubs: [] };
---

<Base title={`${meta.book} · 社会网络分析`} bookSlug={meta.slug} bookName={meta.book} features={meta.features}>
  <BackLink href={`/${meta.slug}`} label={meta.book} />

  <section class="surface relative mt-3 mb-8 overflow-hidden px-6 py-7 sm:px-8">
    <div class="flex items-start gap-4">
      <span class="glyph" style="width:3.6rem;height:3.6rem;font-size:1.9rem">网</span>
      <div>
        <h1 class="brand text-4xl" style="color: var(--primary)">社会网络分析</h1>
        <p class="mt-2 text-sm text-muted">
          帮闲圈介数中心性 · 西门府利益距离 · {data.node_count ?? data.metrics.length} 节点
          {data.bangxian_hubs?.length ? ` · 帮闲 Top ${data.bangxian_hubs.slice(0, 2).join('、')}` : ''}
        </p>
      </div>
    </div>
    <p class="mt-5 max-w-2xl leading-relaxed text-sm" style="color: var(--ink)">
      把西门府人际勾连作为社会网络，定位把控信息与白银流动的关键掮客。
      <strong>J2</strong>：介数 / 度中心性双指标 · 散点图 · 派系筛选；
      <strong>J3</strong>：关系图谱工具栏切换「SNA·介数 / SNA·度」叠加节点大小。
      URL <code>?focus=人物</code> 高亮表格，与
      <a href={`/${meta.slug}/graph`} class="hover:underline" style="color: var(--accent)">关系图谱</a>
      、
      <a href={`/${meta.slug}/silver`} class="hover:underline" style="color: var(--accent)">白银流</a>
      互证。
    </p>
  </section>

  {meta.slug === 'jinpingmei' && <JpmModuleNav bookSlug={meta.slug} features={meta.features} current="sna" />}

  {
    data.metrics.length === 0 ? (
      <div class="surface p-8 text-center text-muted">
        尚无 SNA 数据。请先录入人物并运行
        <code class="mx-1 rounded px-2 py-0.5" style="background: var(--base)">
          python scripts/build_sna.py {meta.book}
        </code>
      </div>
    ) : (
      <div class="kb-dashboard surface mb-10 p-4 sm:p-6">
        <SnaDashboard data={data} bookSlug={meta.slug} client:only="react" />
      </div>
    )
  }
</Base>
