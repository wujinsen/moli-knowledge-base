---
import { getCollection } from 'astro:content';
import { getBooks } from '../../lib/getBooks';
import Base from '../../layouts/Base.astro';
import JpmModuleNav from '../../components/JpmModuleNav.astro';
import SnaPanel from '../../components/SnaPanel.tsx';
import type { SnaData } from '../../lib/sna';

export async function getStaticPaths() {
  const books = await getBooks();
  return books
    .filter((b) => b.data.features.includes('sna'))
    .map((b) => ({ params: { book: b.data.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const meta = book.data;

const files = import.meta.glob('../../data/*.sna.json', { eager: true });
const key = Object.keys(files).find((k) => k.includes(meta.book));
const data: SnaData = key
  ? ((files[key] as { default?: SnaData }).default ?? (files[key] as SnaData))
  : { book: meta.book, metrics: [], hubs: [] };
---

<Base title={`${meta.book} · 社会网络分析`} bookSlug={meta.slug} bookName={meta.book} features={meta.features}>
  <a href={`/${meta.slug}`} class="text-sm hover:underline" style="color: var(--ink-soft)">← {meta.book}</a>

  <section class="surface relative mt-3 mb-8 overflow-hidden px-6 py-7 sm:px-8">
    <div class="flex items-start gap-4">
      <span class="glyph" style="width:3.6rem;height:3.6rem;font-size:1.9rem">网</span>
      <div>
        <h1 class="brand text-4xl" style="color: var(--primary)">社会网络分析</h1>
        <p class="mt-2 text-sm" style="color: var(--ink-soft)">
          帮闲圈介数中心性 · 西门府利益距离 · {data.metrics.length} 节点
        </p>
      </div>
    </div>
    <p class="mt-5 max-w-2xl leading-relaxed text-sm" style="color: var(--ink)">
      把西门府人际勾连作为社会网络，定位把控信息与白银流动的关键掮客——《金瓶梅》作为「社会人类学报告」的核心研究工具。
    </p>
  </section>

  {meta.slug === 'jinpingmei' && <JpmModuleNav bookSlug={meta.slug} features={meta.features} current="sna" />}

  {
    data.metrics.length === 0 ? (
      <div class="surface p-8 text-center" style="color: var(--ink-soft)">
        尚无 SNA 数据。请先录入人物并运行
        <code class="mx-1 rounded px-2 py-0.5" style="background: var(--base)">
          python scripts/build_relations.py {meta.book} --sna
        </code>
      </div>
    ) : (
      <div class="surface mb-10 p-4 sm:p-6">
        <SnaPanel data={data} graphHref={`/${meta.slug}/graph`} client:only="react" />
      </div>
    )
  }
</Base>
