---
import { getBooks } from '../../lib/getBooks';
import Base from '../../layouts/Base.astro';
import BackLink from '../../components/BackLink.astro';
import JpmModuleNav from '../../components/JpmModuleNav.astro';
import FinancialTracks from '../../components/FinancialTracks.tsx';
import ChainTimeline from '../../components/ChainTimeline.tsx';
import { loadEvents } from '../../lib/loadEvents';
import type { FinancialData } from '../../lib/financial';
import { getChainIndex } from '../../lib/chainIndex';
import jpmFinancial from '../../data/jinpingmei.financial.json';

export async function getStaticPaths() {
  const books = await getBooks();
  return books
    .filter((b) => b.data.features.includes('chain'))
    .map((b) => ({ params: { book: b.data.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const meta = book.data;
const readEdition = meta.slug === 'jinpingmei' ? 'cihua' : '1';

const chainIndex = getChainIndex(meta.slug);
const allEvents = await loadEvents(meta.book);
const financialCount =
  chainIndex?.financial_count ??
  allEvents.filter((e) => e.data.subtype === 'financial').length;
const plotCount =
  chainIndex?.plot_count ?? allEvents.filter((e) => e.data.subtype === 'plot').length;

const financialBySlug: Record<string, FinancialData> = {
  jinpingmei: jpmFinancial as FinancialData,
};
const financialData = financialBySlug[meta.slug];
---

<Base title={`${meta.book} · 发家衰败链`} bookSlug={meta.slug} bookName={meta.book} features={meta.features}>
  <BackLink href={`/${meta.slug}`} label={meta.book} />

  <div class="content-page">
  <section class="surface relative mt-3 mb-8 overflow-hidden px-6 py-7 sm:px-8">
    <div class="flex items-start gap-4">
      <span class="glyph" style="width:3.6rem;height:3.6rem;font-size:1.9rem">链</span>
      <div>
        <h1 class="brand text-4xl" style="color: var(--primary)">发家 · 衰败链</h1>
        <p class="mt-2 text-sm text-muted">
          {financialCount} 个白银节点 · {plotCount} 个情节节点 · 按回目串联西门府百年浮沉
          {chainIndex && ` · JSON ${chainIndex.generated}`}
        </p>
      </div>
    </div>
    <p class="mt-5 max-w-2xl text-sm leading-relaxed" style="color: var(--ink)">
      每条
      <code class="rounded px-1" style="background: color-mix(in srgb, var(--primary) 8%, transparent)">event</code>
      含回目锚点、人物/地点与前后置链。<strong>P3</strong> 交易芯片显示金额与摘要；<strong>P4</strong> 与
      <a href={`/${meta.slug}/silver`} class="hover:underline" style="color: var(--accent)">白银流</a>
      （<code>?event=</code>）、
      <a href={`/${meta.slug}/graph`} class="hover:underline" style="color: var(--accent)">关系图谱</a>
      、
      <a href={`/${meta.slug}/sna`} class="hover:underline" style="color: var(--accent)">SNA</a>
      （<code>?focus=</code>）互链。URL 加 <code>?focus=jpm-fe-003</code> 可深链定位节点。
    </p>
  </section>

  {meta.slug === 'jinpingmei' && <JpmModuleNav bookSlug={meta.slug} features={meta.features} current="chain" />}

  {
    financialData && (
      <section class="mb-10">
        <h2 class="section-title mb-4 text-lg">专题轨 · 药铺 / 放债 / 贿赂</h2>
        <div class="kb-dashboard surface p-4 sm:p-6">
          <FinancialTracks data={financialData} bookSlug={meta.slug} client:only="react" />
        </div>
      </section>
    )
  }

  <h2 class="section-title mb-4 text-lg">全书时间轴</h2>
  {
    chainIndex ? (
      <div class="kb-dashboard surface mb-10 p-4 sm:p-6">
        <ChainTimeline
          index={chainIndex}
          bookSlug={meta.slug}
          readEdition={readEdition}
          features={meta.features}
          client:only="react"
        />
      </div>
    ) : (
      <p class="text-sm text-muted">缺少 chain.json，请运行 build_chain.py。</p>
    )
  }

  <div class="surface p-4 text-sm text-muted">
    <span class="chip">数据源</span>
    financial_event + plot · build_chain.py ·
    <a href={`/${meta.slug}/silver`} class="hover:underline" style="color: var(--accent)">白银流</a>
    {meta.features.includes('sna') && (
      <>
        {' · '}
        <a href={`/${meta.slug}/sna`} class="hover:underline" style="color: var(--accent)">社会网络</a>
      </>
    )}
    {meta.features.includes('graph') && (
      <>
        {' · '}
        <a href={`/${meta.slug}/graph`} class="hover:underline" style="color: var(--accent)">关系图谱</a>
      </>
    )}
    {meta.features.includes('town') && (
      <>
        {' · '}
        <a href={`/${meta.slug}/town`} class="hover:underline" style="color: var(--accent)">市井地图</a>
      </>
    )}
    {meta.slug === 'jinpingmei' && (
      <>
        {' · '}
        <a href={`/${meta.slug}/litigation`} class="hover:underline" style="color: var(--accent)">诉讼推演</a>
        {' · '}
        <a href={`/${meta.slug}/topics/世情与贵族衰败对比`} class="hover:underline" style="color: var(--accent)">金红对比</a>
      </>
    )}
  </div>
  </div>
</Base>
