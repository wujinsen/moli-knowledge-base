---
import { getCollection } from 'astro:content';
import { getBooks } from '../../lib/getBooks';
import GraphLayout from '../../layouts/GraphLayout.astro';
import BackLink from '../../components/BackLink.astro';
import GardenMap from '../../components/GardenMap.tsx';
import gardenSnapshot from '../../data/红楼梦.garden_map.json';
import {
  attachEventsToNodes,
  buildGardenEdges,
  ZONE_ORDER,
  type GardenEventRef,
  type GardenMapNode,
  type GardenZone,
} from '../../lib/gardenMap';

export async function getStaticPaths() {
  const books = await getBooks();
  return books
    .filter((b) => b.data.features.includes('garden'))
    .map((b) => ({ params: { book: b.data.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const meta = book.data;

const locations = (await getCollection('locations')).filter(
  (l) => l.data.book === meta.book && l.data.coord && l.data.garden_zone,
);

const gardenEvents: GardenEventRef[] = (await getCollection('events'))
  .filter((e) => e.data.book === meta.book)
  .map((e) => ({
    id: e.data.id,
    title: e.data.title,
    chapters: e.data.chapters,
    locations: e.data.locations ?? [],
  }));

function chaptersFromAppearIn(appearIn: string[]): number[] {
  return [
    ...new Set(
      appearIn
        .map((s) => {
          const m = s.match(/第(\d+)回/);
          return m ? Number(m[1]) : null;
        })
        .filter((n): n is number => n != null),
    ),
  ].sort((a, b) => a - b);
}

function nodeFromLocation(d: (typeof locations)[number]['data']): GardenMapNode {
  return {
    id: d.id,
    name: d.name,
    zone: d.garden_zone!,
    category: d.category,
    x: d.coord!.x,
    y: d.coord!.y,
    tourOrder: d.tour_order ?? null,
    summary: d.summary ?? '',
    chapters: chaptersFromAppearIn(d.appear_in),
    occupants: d.occupants,
    plants: d.plants,
    plaque: d.plaque,
    couplet: d.couplet,
    nearby: d.nearby,
    events: [],
  };
}

type SnapshotNode = (typeof gardenSnapshot)['nodes'][number];

function nodeFromSnapshot(n: SnapshotNode): GardenMapNode {
  return {
    id: n.id,
    name: n.name,
    zone: n.zone as GardenZone,
    category: n.category,
    x: n.x,
    y: n.y,
    tourOrder: n.tourOrder ?? null,
    summary: n.summary ?? '',
    chapters: n.chapters ?? [],
    occupants: n.occupants ?? [],
    plants: n.plants ?? [],
    plaque: n.plaque,
    couplet: n.couplet,
    nearby: n.nearby ?? [],
    events: [],
  };
}

const baseNodes: GardenMapNode[] =
  locations.length > 0
    ? locations.map((l) => nodeFromLocation(l.data))
    : gardenSnapshot.nodes.map(nodeFromSnapshot);

const nodes = attachEventsToNodes(baseNodes, gardenEvents);
const gardenData = { nodes, edges: buildGardenEdges(nodes) };
const zoneCounts = Object.fromEntries(
  ZONE_ORDER.map((z) => [z, nodes.filter((n) => n.zone === z).length]),
);
---

<GraphLayout
  title={`${meta.book} 大观园地图`}
  bookSlug={meta.slug}
  bookName={meta.book}
  features={meta.features}
  moduleKey="maps"
  moduleLabel="大观园地图"
>
  {
    nodes.length === 0 ? (
      <div class="flex min-h-[70vh] flex-col items-center justify-center px-4 text-center text-slate-300">
        <p class="mb-2 text-lg">大观园地图待生成</p>
        <p class="max-w-md text-sm text-slate-400">
          运行
          <code class="mx-1 rounded bg-slate-800 px-2 py-0.5 text-amber-300">
            python scripts/seed_garden_coords.py --write
          </code>
          注入坐标，再运行
          <code class="mx-1 rounded bg-slate-800 px-2 py-0.5 text-amber-300">
            python scripts/build_garden_map_manifest.py --write
          </code>
          生成地图快照。
        </p>
        <BackLink href={`/${meta.slug}`} label={meta.book} variant="dark" class="mt-6" />
      </div>
    ) : (
      <>
        <div class="pointer-events-none absolute left-1/2 top-3 z-20 -translate-x-1/2 text-center sm:hidden">
          <span class="text-sm font-medium text-slate-300">
            {ZONE_ORDER.filter((z) => zoneCounts[z] > 0)
              .map((z) => `${z} ${zoneCounts[z]}`)
              .join(' · ')}
          </span>
        </div>
        <GardenMap data={gardenData} bookSlug={meta.slug} client:only="react" />
      </>
    )
  }
</GraphLayout>
