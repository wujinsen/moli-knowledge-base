---
import { getBooks } from '../../lib/getBooks';
import GraphLayout from '../../layouts/GraphLayout.astro';
import BackLink from '../../components/BackLink.astro';
import RelationGraph from '../../components/RelationGraph.tsx';
import { graphTheme } from '../../lib/graphTheme';
import { relationGraphForSlug } from '../../lib/relations';

export async function getStaticPaths() {
  const books = await getBooks();
  return books
    .filter((b) => b.data.features.includes('graph'))
    .map((b) => ({ params: { book: b.data.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const meta = book.data;
const gt = graphTheme(meta.slug);
const data = relationGraphForSlug(meta.slug);
---

<GraphLayout
  title={`${meta.book} 关系图谱`}
  bookSlug={meta.slug}
  bookName={meta.book}
  features={meta.features}
>
  {
    data.nodes.length === 0 ? (
      <div class="flex h-full min-h-[50vh] flex-col items-center justify-center px-4 text-center">
        <div
          class="brand mb-5 grid h-20 w-20 place-items-center rounded-2xl text-4xl"
          style={`color:${gt.accentSoft};border:1.5px solid ${gt.accentLine};background:${gt.base}`}
        >
          {meta.book.slice(0, 1)}
        </div>
        <p class="mb-2 text-lg" style={`color:${gt.accentSoft}`}>关系图谱待生成</p>
        <p class="max-w-md text-sm text-slate-400">
          {meta.book} 的人物 / 社会网尚未注入。运行
          <code class="mx-1 rounded px-2 py-0.5" style={`background:${gt.base};color:${gt.accent}`}>
            python scripts/build_relations.py {meta.book}
          </code>
          生成图谱数据。
        </p>
        <BackLink href={`/${meta.slug}`} label={meta.book} variant="dark" class="mt-6" />
      </div>
    ) : (
      <>
        <RelationGraph bookSlug={meta.slug} client:only="react">
        <div
          slot="fallback"
          class="graph-explorer flex flex-col items-center justify-center gap-3 px-4 text-center text-slate-400"
          style="height: calc(100dvh - var(--graph-chrome, 10.5rem)); min-height: calc(100dvh - var(--graph-chrome, 10.5rem));"
        >
          <div
            class="h-8 w-8 animate-spin rounded-full border-2 border-slate-600 border-t-slate-300"
            aria-hidden="true"
          />
          <p class="text-sm">加载关系图谱…</p>
        </div>
        </RelationGraph>
      </>
    )
  }
</GraphLayout>
