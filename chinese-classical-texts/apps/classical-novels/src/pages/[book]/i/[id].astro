---
import { getCollection } from 'astro:content';
import { getBooks } from '../../../lib/getBooks';
import Base from '../../../layouts/Base.astro';
import BackLink from '../../../components/BackLink.astro';
import { kindLabel, loadBookItems, getItemEntry, type ItemKind } from '../../../lib/items';
import { catalogHrefForKind, catalogLabelForKind } from '../../../lib/materialModules';
import {
  chaptersFromAppearIn,
  itemLocationId,
  relatedItemsAtSameLocation,
} from '../../../lib/crosslinks';
import {
  buildEntityIndex,
  isEntityMetaLabel,
  renderWikiMarkdownBody,
} from '../../../lib/entityLinks';
import { getItemTopicLinks } from '../../../lib/itemsTopicLinks';
import EntityNameLink from '../../../components/EntityNameLink.astro';
import EntityNameLinks from '../../../components/EntityNameLinks.astro';

export async function getStaticPaths() {
  const books = await getBooks();
  const slugByBook = new Map(books.map((b) => [b.data.book, b.data.slug]));
  const paths: { params: { book: string; id: string }; props: { slug: string; kind: ItemKind; entry: any; features: string[] } }[] = [];

  for (const b of books.filter((x) => x.data.features.includes('items'))) {
    const items = await loadBookItems(b.data.book);
    for (const { kind, entry } of items) {
      paths.push({
        params: { book: slugByBook.get(b.data.book)!, id: entry.data.id },
        props: { slug: slugByBook.get(b.data.book)!, kind, entry, features: b.data.features },
      });
    }
  }
  return paths;
}

const { slug, kind, entry, features } = Astro.props;
const d = entry.data;
const fullEntry = (await getItemEntry(kind, d.id)) ?? entry;
const entityIndex = await buildEntityIndex(d.book);
const proseHtml = await renderWikiMarkdownBody(fullEntry.body ?? '', entityIndex, slug);

const metaRows: [string, string | undefined][] = [];
if (kind === 'artifact') {
  metaRows.push(
    ['类别', d.category ?? d.type],
    ['制造', d.maker],
    ['持有', d.owner],
    ['重量', d.weight],
    ['首现', d.first_appear],
  );
} else if (kind === 'medicine') {
  metaRows.push(
    ['类别', d.category],
    ['对象', d.patient],
    ['开方', d.prescriber ?? d.physician],
    ['证候', d.syndrome],
    ['首现', d.first_appear],
  );
} else if (kind === 'dish') {
  metaRows.push(
    ['类别', d.category ?? d.type],
    ['地点', d.location],
    ['场合', d.occasion],
    ['估价', d.cost_estimate],
    ['首现', d.first_appear],
  );
} else if (kind === 'costume') {
  metaRows.push(
    ['穿戴', d.wearer],
    ['材质', d.material],
    ['颜色', d.color],
    ['场合', d.occasion],
    ['首现', d.first_appear],
  );
} else {
  metaRows.push(
    ['地点', d.location],
    ['费用', d.economic],
    ['礼制', d.legal_norm],
    ['首现', d.first_appear],
  );
}

const locationId = itemLocationId(entry);
const samePlace = await relatedItemsAtSameLocation(d.book, locationId, d.id);
const chapterNums = chaptersFromAppearIn(d.appear_in ?? []);
const catalogHref = catalogHrefForKind(slug, kind);
const catalogLabel = catalogLabelForKind(kind);
const artifactData = kind === 'artifact' ? (d as typeof d & { abilities?: string[]; counters?: string[]; relations?: { target: string; type: string; note?: string }[] }) : null;
const allItems = await loadBookItems(d.book);
const counterRefs = artifactData?.counters?.map((id) => allItems.find((i) => i.entry.data.id === id)).filter(Boolean) ?? [];
const relatedTopics = getItemTopicLinks(slug, d.id);
---

<Base title={d.name} bookSlug={slug} bookName={d.book} features={features}>
  <BackLink href={catalogHref} label={catalogLabel} />
  <div
    class="content-page entity-detail"
    data-pagefind-body
    data-pagefind-meta={`title:${d.name}`}
    data-pagefind-filter={`书:${d.book},类型:${kindLabel(kind)}`}
  >
    <div class="mt-3 flex items-center gap-3">
      <h1 class="brand text-4xl" style="color: var(--primary)">{d.name}</h1>
      <span class="chip chip-md">{kindLabel(kind)}</span>
    </div>

    {
      d.summary && <p class="page-lead mt-2">{d.summary}</p>
    }

    <div class="entity-spec surface mt-4 grid gap-2.5 p-4 sm:grid-cols-2 sm:p-5">
      {
        metaRows
          .filter(([, v]) => v)
          .map(([label, value]) => (
            <div>
              {label}：
              {isEntityMetaLabel(label) && value ? (
                <EntityNameLink name={value} index={entityIndex} slug={slug} />
              ) : (
                value
              )}
            </div>
          ))
      }
      {
        d.eaters?.length > 0 && (
          <div>
            食用：<EntityNameLinks names={d.eaters} index={entityIndex} slug={slug} />
          </div>
        )
      }
      {
        d.ingredients?.length > 0 && (
          <div>
            配料：<EntityNameLinks names={d.ingredients} index={entityIndex} slug={slug} />
          </div>
        )
      }
      {
        d.participants?.length > 0 && (
          <div>
            参与者：<EntityNameLinks names={d.participants} index={entityIndex} slug={slug} />
          </div>
        )
      }
      {
        artifactData?.abilities && artifactData.abilities.length > 0 && (
          <div>能力：{artifactData.abilities.join('、')}</div>
        )
      }
      {
        locationId && (
          <div>
            地点：<a class="hover:underline" style="color: var(--primary)" href={`/${slug}/l/${locationId}`}>{locationId}</a>
          </div>
        )
      }
    </div>

    {
      counterRefs.length > 0 && (
        <div class="entity-detail-links mt-6">
          <h2 class="section-title mb-2.5">克制关系</h2>
          <div class="flex flex-wrap gap-2.5">
            {counterRefs.map((item) => item && (
              <a href={`/${slug}/i/${item.entry.data.id}`} class="chip chip-md hover:underline">
                {item.entry.data.name}
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      artifactData?.relations && artifactData.relations.length > 0 && (
        <div class="entity-detail-links mt-6">
          <h2 class="section-title mb-2.5">谱系关系</h2>
          <ul class="entity-detail-relations space-y-2">
            {artifactData.relations.map((rel) => (
              <li>
                {rel.type}：
                <a class="hover:underline" style="color: var(--primary)" href={`/${slug}/c/${rel.target}`}>
                  {rel.target}
                </a>
                {rel.note ? `（${rel.note}）` : ''}
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <article class="entity-detail-prose prose-cn mt-8 max-w-none" set:html={proseHtml} />

    {
      samePlace.length > 0 && (
        <div class="entity-detail-links mt-6">
          <h2 class="section-title mb-2.5">同地其他名物</h2>
          <div class="flex flex-wrap gap-2.5">
            {samePlace.map((item) => (
              <a href={`/${slug}/i/${item.id}`} class="chip chip-md hover:underline">
                {item.name}
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      relatedTopics.length > 0 && (
        <div class="entity-detail-links mt-6">
          <h2 class="section-title mb-2.5">相关纵切主题</h2>
          <div class="flex flex-wrap gap-2.5">
            {relatedTopics.map((t) => (
              <a href={`/${slug}/topics/${t.slug}`} class="chip chip-md hover:underline">
                {t.title}
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      chapterNums.length > 0 && (
        <div class="entity-detail-links mt-6">
          <h2 class="section-title mb-2.5">相关回目</h2>
          <div class="flex flex-wrap gap-2.5">
            {chapterNums.map((num) => (
              <a href={`/${slug}/read/${num}`} class="chip chip-md hover:underline">
                第{num}回
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>
</Base>
