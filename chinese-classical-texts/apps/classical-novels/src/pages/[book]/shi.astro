---
import { getCollection } from 'astro:content';
import { getBooks } from '../../lib/getBooks';
import Base from '../../layouts/Base.astro';
import BackLink from '../../components/BackLink.astro';
import CatalogFoldBar from '../../components/CatalogFoldBar.astro';
import CatalogFoldSection from '../../components/CatalogFoldSection.astro';
import ImageryGraph from '../../components/ImageryGraph.tsx';
import {
  buildImageryGraph,
  chapterLabel,
  sortImagery,
  subtypeLabel,
} from '../../lib/imagery';
import type { ImageryGraphEdge } from '../../lib/imagery';

export async function getStaticPaths() {
  const books = await getBooks();
  return books
    .filter((b) => b.data.features.includes('poems'))
    .map((b) => ({ params: { book: b.data.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const meta = book.data;
const items = sortImagery(
  (await getCollection('imagery')).filter((i) => i.data.book === meta.book),
);

const linkFiles = import.meta.glob('../../data/*.imagery-links.json', { eager: true });
const linkKey = Object.keys(linkFiles).find((k) => k.includes(meta.book));
const extraRaw = linkKey ? (linkFiles[linkKey] as { default?: { links: ImageryGraphEdge[] }; links?: ImageryGraphEdge[] }) : null;
const extraLinks: ImageryGraphEdge[] = extraRaw?.default?.links ?? extraRaw?.links ?? [];

const graph = buildImageryGraph(items, extraLinks);
const bySubtype = (st: string) => items.filter((i) => i.data.subtype === st);

const SUBTYPE_ORDER = [
  'myth', 'judgment', 'poem', 'symbol', 'flower_lot',
  'tune_omen', 'name_omen', 'object_omen',
  'alchemy', 'place_omen',
];
const presentSubtypes = SUBTYPE_ORDER.filter((st) => bySubtype(st).length > 0);
const presentLabels = presentSubtypes.map(subtypeLabel).join(' / ');

const SUBTYPE_GLYPH: Record<string, string> = {
  myth: '幻', judgment: '谶', poem: '吟', symbol: '象', flower_lot: '签',
  tune_omen: '曲', name_omen: '名', object_omen: '物',
  alchemy: '丹', place_omen: '境',
};

const isJpm = meta.slug === 'jinpingmei';
const isXyj = meta.slug === 'xiyouji';
---

<Base title={`${meta.book} · 诗词意象`} bookSlug={meta.slug} bookName={meta.book} features={meta.features}>
  <BackLink href={`/${meta.slug}`} label={meta.book} />

  <div class="content-page">
  <section class="surface relative mt-3 mb-8 overflow-hidden px-6 py-7 sm:px-8">
    <div class="flex items-start gap-4">
      <span class="glyph" style="width:3.6rem;height:3.6rem;font-size:1.9rem">诗</span>
      <div>
        <h1 class="brand text-4xl" style="color: var(--primary)">{isJpm ? '名物谶纬 · 因果闭环' : isXyj ? '丹道意象 · 修心网络' : '诗词意象 · 互文网络'}</h1>
        <p class="mt-2 text-sm text-muted">
          {items.length} 条意象实体 · {graph.edges.length} 条关联边 · {presentLabels}
        </p>
      </div>
    </div>
    <p class="mt-5 max-w-2xl text-sm leading-relaxed" style="color: var(--ink)">
      {isJpm ? (
        <Fragment>
          世情物语的核心：以「谐音双关 + 物象隐喻」连成「欲起→聚敛→极盛→反噬→散尽」的因果报应闭环，边按张竹坡<strong>冷热金针</strong>标注冷热（<code class="rounded px-1" style="background: color-mix(in srgb, var(--primary) 8%, transparent)">temperature</code>）。
          点击下方<strong>示例链路</strong>可在网络图中切换高亮路径。
        </Fragment>
      ) : isXyj ? (
        <Fragment>
          内丹解经的核心：心猿（金）· 意马 · 木母 · 黄婆（土）· 婴儿（火）· 姹女（水）构成丹道符号系统，以<strong>金木相克/交并 · 黄婆调和 · 水火相济</strong>为关系边，并把火焰山、通天河等地名作环境节点（联动 <code class="rounded px-1" style="background: color-mix(in srgb, var(--primary) 8%, transparent)">quanshi</code> 内丹视角）。
          点击下方<strong>示例链路</strong>可在修心网络中切换高亮路径。
        </Fragment>
      ) : (
        <Fragment>
          图谶式文本的核心：表层意象与人物命运的「隐喻」推论边（<code class="rounded px-1" style="background: color-mix(in srgb, var(--primary) 8%, transparent)">inference</code>）。
          点击下方<strong>示例链路</strong>可在互文图中切换高亮路径。
        </Fragment>
      )}
    </p>
  </section>

  <h2 class="section-title mb-4 text-lg">意象互文图</h2>
  <div class="kb-dashboard surface mb-10 p-4 sm:p-6">
    <ImageryGraph
      graph={graph}
      bookSlug={meta.slug}
      client:only="react"
    />
  </div>

  <div class="catalog-fold-page">
    {presentSubtypes.length > 0 && <CatalogFoldBar label="意象分类" />}

    {
      presentSubtypes.map((st) => {
        const group = bySubtype(st);
        if (group.length === 0) return null;
        return (
          <CatalogFoldSection id={st} title={subtypeLabel(st)} count={group.length}>
            <div class="grid gap-3 sm:grid-cols-2">
              {
                group.map((item) => {
                  const d = item.data;
                  const infCount = d.links.filter((l) => l.inference).length;
                  return (
                    <a href={`/${meta.slug}/imagery/${d.id}`} class="module-card">
                      <span class="glyph" style="font-size:1.2rem;width:2.6rem;height:2.6rem">
                        {SUBTYPE_GLYPH[st] ?? '象'}
                      </span>
                      <div class="min-w-0">
                        <h3 class="font-bold" style="color: var(--primary)">{d.title}</h3>
                        {d.text && (
                          <p class="mt-1 line-clamp-2 text-sm text-muted">{d.text}</p>
                        )}
                        <div class="mt-2 flex flex-wrap gap-2 text-xs">
                          {d.chapters[0] != null && (
                            <span class="chip">{chapterLabel(d.chapters)}</span>
                          )}
                          {d.characters.map((c) => <span class="chip">{c}</span>)}
                          {infCount > 0 && (
                            <span class="chip" title="推论边">推论 ×{infCount}</span>
                          )}
                        </div>
                      </div>
                    </a>
                  );
                })
              }
            </div>
          </CatalogFoldSection>
        );
      })
    }
  </div>
  </div>
</Base>
