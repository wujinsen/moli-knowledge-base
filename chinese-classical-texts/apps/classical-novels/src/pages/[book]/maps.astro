---
import { getBooks } from '../../lib/getBooks';
import GraphLayout from '../../layouts/GraphLayout.astro';
import BackLink from '../../components/BackLink.astro';
import { bookHasLiveMaps, bookMapEntries } from '../../lib/bookMaps';
import { MAP_BRIDGE_SUMMARY, MAP_LAYER_NESTING } from '../../lib/bookMapCrosslinks';
import { graphTheme } from '../../lib/graphTheme';

export async function getStaticPaths() {
  const books = await getBooks();
  return books
    .filter((b) => b.data.slug === 'honglou' && bookHasLiveMaps(b.data.slug, b.data.features))
    .map((b) => ({ params: { book: b.data.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const meta = book.data;
const gt = graphTheme(meta.slug);
const entries = bookMapEntries(meta.slug, meta.features);
const liveCount = entries.filter((e) => e.status === 'live').length;
---

<GraphLayout
  title={`${meta.book} 空间地图`}
  bookSlug={meta.slug}
  bookName={meta.book}
  features={meta.features}
  moduleKey="maps"
  moduleLabel="空间地图"
>
  <div class="mx-auto max-w-6xl px-4 py-10">
    <p class="mb-3 text-sm leading-relaxed text-slate-300">
      五张图层均已上线：逻辑拓扑示意（非测绘定稿），坐标以 wiki inference 为准；各图独立维护导览线与视觉标注。
    </p>
    <p class="mb-8 rounded-lg border border-white/10 bg-slate-900/50 px-4 py-3 text-xs leading-relaxed text-slate-400">
      <span class="font-medium text-slate-300">嵌套关系：</span>
      {MAP_LAYER_NESTING}
      <span class="mt-1 block text-slate-500">
        {MAP_BRIDGE_SUMMARY}
        · 侧栏选节点或数字文旅墙外标注可见跨图链接
      </span>
    </p>

    <div class="grid gap-4 sm:grid-cols-2">
      {
        entries.map((entry) =>
          entry.status === 'live' && entry.href ? (
            <a
              href={entry.href}
              class="group rounded-xl border border-white/10 bg-slate-900/60 p-5 transition hover:border-white/25 hover:bg-slate-900/80"
            >
              <div class="mb-2 flex items-center justify-between gap-2">
                <h2 class="text-lg font-semibold text-slate-100 group-hover:text-white">{entry.title}</h2>
                {entry.badge && (
                  <span
                    class="shrink-0 rounded px-2 py-0.5 text-xs"
                    style={{ backgroundColor: `${gt.accent}22`, color: gt.accentSoft }}
                  >
                    {entry.badge}
                  </span>
                )}
              </div>
              <p class="text-sm leading-relaxed text-slate-400">{entry.desc}</p>
              <span class="mt-3 inline-block text-sm font-medium" style={{ color: gt.accent }}>
                {entry.key === 'digital-tour'
                  ? '进入标注导览 →'
                  : entry.key === 'scene'
                    ? '进入 2.5D →'
                    : '进入地图 →'}
              </span>
            </a>
          ) : (
            <div class="rounded-xl border border-dashed border-white/10 bg-slate-900/30 p-5 opacity-70">
              <div class="mb-2 flex items-center justify-between gap-2">
                <h2 class="text-lg font-semibold text-slate-400">{entry.title}</h2>
                <span class="seal seal-planned shrink-0 text-xs">规划中</span>
              </div>
              <p class="text-sm leading-relaxed text-slate-500">{entry.desc}</p>
            </div>
          ),
        )
      }
    </div>

    <p class="mt-8 text-center text-xs text-slate-600">
      已上线 {liveCount} 张 · seed 脚本：garden / manor / capital coords · 数字文旅 pin JSON
    </p>

    <BackLink href={`/${meta.slug}`} label={meta.book} variant="dark" class="mt-8" />
  </div>
</GraphLayout>
