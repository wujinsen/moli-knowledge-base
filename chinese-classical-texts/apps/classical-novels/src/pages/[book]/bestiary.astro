---
import { getCollection } from 'astro:content';
import { getBooks } from '../../lib/getBooks';
import Base from '../../layouts/Base.astro';
import CharacterCard from '../../components/CharacterCard.astro';

export async function getStaticPaths() {
  const books = await getBooks();
  return books.map((b) => ({
    params: { book: b.data.slug },
    props: { book: b },
  }));
}

const { book } = Astro.props;
const meta = book.data;
const isJpm = meta.slug === 'jinpingmei';

const entries = (await getCollection('characters'))
  .filter((c) => c.data.book === meta.book)
  .sort((a, b) => (b.data.weight ?? 0) - (a.data.weight ?? 0));

const characters = entries.filter((c) => c.data.type === 'character');
const monsters = entries.filter((c) => c.data.type === 'monster');

const JPM_FACTION_ORDER = ['西门府', '帮闲圈', '清河县', '朝廷'] as const;

function groupByFaction(list: typeof characters) {
  const map = new Map<string, typeof characters>();
  for (const c of list) {
    const f = c.data.faction ?? '其他';
    if (!map.has(f)) map.set(f, []);
    map.get(f)!.push(c);
  }
  const keys = [...map.keys()].sort((a, b) => {
    const ia = JPM_FACTION_ORDER.indexOf(a as (typeof JPM_FACTION_ORDER)[number]);
    const ib = JPM_FACTION_ORDER.indexOf(b as (typeof JPM_FACTION_ORDER)[number]);
    const ai = ia === -1 ? 999 : ia;
    const bi = ib === -1 ? 999 : ib;
    return ai - bi || a.localeCompare(b, 'zh-CN');
  });
  return keys.map((k) => ({ faction: k, items: map.get(k)! }));
}

const jpmGroups = isJpm ? groupByFaction(characters) : [];
const withBacking = characters.filter((c) => c.data.靠山).length;
const withOutcome = characters.filter((c) => c.data.结局).length;
---

<Base title={`${meta.book} 图鉴`} bookSlug={meta.slug} bookName={meta.book} features={meta.features}>
  {
    isJpm ? (
      <p slot="module-extra" class="mt-2 text-sm" style="color: var(--ink-soft)">
        妻妾 · 帮闲 · 政商群像 · {characters.length} 人
        <span class="mx-1">·</span>
        {withBacking} 有靠山 · {withOutcome} 有结局
        <a href={`/${meta.slug}/graph`} class="ml-2 hover:underline" style="color: var(--accent)">
          社会网 →
        </a>
        <a href={`/${meta.slug}/sna`} class="ml-2 hover:underline" style="color: var(--accent)">
          SNA →
        </a>
      </p>
    ) : (
      <p slot="module-extra" class="mt-2 text-sm" style="color: var(--ink-soft)">
        登场人物与妖怪群像 · {characters.length} 人物
        {monsters.length > 0 && ` · ${monsters.length} 妖怪`}
      </p>
    )
  }

  {
    isJpm && (
      <div class="mb-6 flex flex-wrap gap-2 text-xs" style="color: var(--ink-soft)">
        <span class="chip">亲缘 = 西门府内</span>
        <span class="chip">雇佣 = 仆佣</span>
        <span class="chip">利益交换 = 帮闲/商贾</span>
        <span class="chip">外人 = 政敌或远端</span>
      </div>
    )
  }

  {
    isJpm ? (
      jpmGroups.map(({ faction, items }) => (
        <section class="mb-10">
          <h2 class="section-title mb-3 text-lg">
            {faction}（{items.length}）
          </h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {items.map((c) => (
              <CharacterCard
                href={`/${meta.slug}/c/${c.data.id}`}
                name={c.data.name}
                type={c.data.type}
                faction={c.data.faction}
                summary={c.data.summary}
                tags={c.data.tags}
                proximity={c.data.ximen_proximity}
                backing={c.data.靠山}
                attach={c.data.依附}
                outcome={c.data.结局}
              />
            ))}
          </div>
        </section>
      ))
    ) : (
      <>
        <h2 class="section-title mb-3 text-lg">人物（{characters.length}）</h2>
        <div class="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            characters.map((c) => (
              <CharacterCard
                href={`/${meta.slug}/c/${c.data.id}`}
                name={c.data.name}
                type={c.data.type}
                faction={c.data.faction}
                summary={c.data.summary}
                tags={c.data.tags}
                backing={c.data.靠山}
                attach={c.data.依附}
                outcome={c.data.结局}
              />
            ))
          }
        </div>
      </>
    )
  }

  {
    monsters.length > 0 && (
      <>
        <h2 class="section-title mb-3 text-lg">妖怪（{monsters.length}）</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {monsters.map((c) => (
            <CharacterCard
              href={`/${meta.slug}/c/${c.data.id}`}
              name={c.data.name}
              type={c.data.type}
              faction={c.data.faction}
              summary={c.data.summary}
              tags={c.data.tags}
              outcome={c.data.结局}
            />
          ))}
        </div>
      </>
    )
  }
</Base>
