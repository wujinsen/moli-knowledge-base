---
import { getCollection } from 'astro:content';
import { getBooks } from '../../lib/getBooks';
import Base from '../../layouts/Base.astro';
import CharacterCard from '../../components/CharacterCard.astro';
import { bestiaryStatsFor, buildBestiaryGroupings } from '../../lib/bestiaryGroups';
import { buildFullRosterList, loadCharacterRoster, loadCharacterScope } from '../../lib/characterRoster';
import { cardOutcome } from '../../lib/bestiary';

export async function getStaticPaths() {
  const books = await getBooks();
  return books.map((b) => ({
    params: { book: b.data.slug },
    props: { book: b },
  }));
}

const { book } = Astro.props;
const meta = book.data;
const slug = meta.slug;

const entries = (await getCollection('characters'))
  .filter((c) => c.data.book === meta.book)
  .sort((a, b) => (b.data.weight ?? 0) - (a.data.weight ?? 0));

/** SNA 中心度（若存在 <slug>.sna.json）→ id → degree_norm */
const snaModules = import.meta.glob('../../data/*.sna.json', { eager: true });
const snaEntry = Object.entries(snaModules).find(([p]) => p.endsWith(`/${slug}.sna.json`));
let centrality: Map<string, number> | undefined;
if (snaEntry) {
  const sna = (snaEntry[1] as { default?: { metrics?: { id: string; degree_norm?: number }[] } }).default ??
    (snaEntry[1] as { metrics?: { id: string; degree_norm?: number }[] });
  const metrics = sna.metrics ?? [];
  if (metrics.length > 0) centrality = new Map(metrics.map((m) => [m.id, m.degree_norm ?? 0]));
}

/** 多维分组：首项恒为「身份名册」，其余按字段覆盖度自动启用 */
const groupings = buildBestiaryGroupings(slug, entries, { centrality });
const stats = bestiaryStatsFor(slug, entries);

const rosterData = loadCharacterRoster(slug);
const characterScope = loadCharacterScope(slug);
const pendingList = rosterData?.pending ?? [];
const fullRoster = buildFullRosterList(slug, entries, pendingList);
const totalMentioned = stats.total + pendingList.length;
const rosterBreakdown =
  stats.monsterCount != null
    ? `${stats.characterCount} 已建页 · ${stats.monsterCount} 妖怪 · ${pendingList.length} 待补建`
    : `${stats.total} 已建页 · ${pendingList.length} 待补建`;

function cardProps(c: (typeof entries)[number]) {
  return {
    href: `/${slug}/c/${c.data.id}`,
    name: c.data.name,
    type: c.data.type,
    bookSlug: slug,
    faction: c.data.faction,
    summary: c.data.summary,
    tags: c.data.tags,
    proximity: c.data.ximen_proximity,
    backing: c.data.靠山,
    attach: c.data.依附,
    outcome: cardOutcome(c.data) ?? c.data.结局,
    personality: c.data.性格,
    likes: c.data.喜好,
  };
}
---

<Base title={`${meta.book} 图鉴`} bookSlug={slug} bookName={meta.book} features={meta.features}>
  {
    slug === 'jinpingmei' ? (
      <p slot="module-extra" class="text-muted mt-2 text-sm">
        {stats.groupCount} 组 · {stats.total} 人
        <span class="mx-1">·</span>
        {stats.withPersonality} 有性格 · {stats.withLikes} 有喜好
        <span class="mx-1">·</span>
        {stats.withBacking} 有靠山 · {stats.withOutcome} 有结局
        <a href={`/${slug}/graph`} class="ml-2 hover:underline" style="color: var(--accent)">
          社会网 →
        </a>
        <a href={`/${slug}/sna`} class="ml-2 hover:underline" style="color: var(--accent)">
          SNA →
        </a>
      </p>
    ) : slug === 'honglou' ? (
      <p slot="module-extra" class="text-muted mt-2 text-sm">
        {stats.groupCount} 组 · {stats.total} 人
        <span class="mx-1">·</span>
        {stats.withPersonality} 有性格 · {stats.withLikes} 有喜好
        <span class="mx-1">·</span>
        {stats.withOutcome} 有结局
        <a href={`/${slug}/graph`} class="ml-2 hover:underline" style="color: var(--accent)">
          关系网 →
        </a>
        <a href={`/${slug}/i`} class="ml-2 hover:underline" style="color: var(--accent)">
          名物 →
        </a>
      </p>
    ) : slug === 'xiyouji' ? (
      <p slot="module-extra" class="text-muted mt-2 text-sm">
        {stats.groupCount} 组 · {stats.characterCount} 人物 · {stats.monsterCount} 妖怪
        <span class="mx-1">·</span>
        本库 {stats.total} 页 · 学界具名约 1200
        <span class="mx-1">·</span>
        {stats.withPersonality} 有性格 · {stats.withLikes} 有喜好
        <span class="mx-1">·</span>
        {stats.withOutcome} 有结局
        <a href={`/${slug}/graph`} class="ml-2 hover:underline" style="color: var(--accent)">
          关系网 →
        </a>
        <a href={`/${slug}/nan`} class="ml-2 hover:underline" style="color: var(--accent)">
          八十一难 →
        </a>
      </p>
    ) : (
      <p slot="module-extra" class="text-muted mt-2 text-sm">
        登场人物与妖怪群像 · {stats.total} 人
      </p>
    )
  }

  <div class="bestiary-page">
  <details class="bestiary-roster surface mb-8" open>
    <summary class="bestiary-roster-summary">
      <span class="bestiary-roster-title">全部人物名录</span>
      <span class="bestiary-roster-count">
        全书提及 {totalMentioned} 位（{rosterBreakdown}）
      </span>
      <span class="bestiary-roster-hint">已建页可点击追溯 · 灰色为待补建</span>
    </summary>
    {
      characterScope && (
        <div class="bestiary-scope mb-4">
          <p class="bestiary-scope-lead">{characterScope.summary}</p>
          <div class="bestiary-scope-estimates">
            {characterScope.estimates.map((e) => (
              <div class="bestiary-scope-estimate">
                <span class="bestiary-scope-estimate-label">{e.label}</span>
                <span class="bestiary-scope-estimate-count">{e.count}</span>
                <span class="bestiary-scope-estimate-note">{e.note}</span>
              </div>
            ))}
          </div>
          <p class="bestiary-scope-kb-note">
            本库当前收录 <strong>{totalMentioned}</strong> 位（{rosterBreakdown}），持续 ingest 补页；下表为图谱圈层参考（学界估计，inference）。
          </p>
          <div class="bestiary-scope-layers">
            {characterScope.layers.map((layer) => (
              <div class="bestiary-scope-layer">
                <div class="bestiary-scope-layer-head">
                  <span class="bestiary-scope-layer-name">{layer.name}</span>
                  <span class="bestiary-scope-layer-count">约 {layer.count} 人</span>
                </div>
                <p class="bestiary-scope-layer-members">{layer.members}</p>
                <p class="bestiary-scope-layer-role">{layer.role}</p>
              </div>
            ))}
          </div>
          <p class="bestiary-scope-sources text-muted">
            出处：{characterScope.sources.join(' · ')}
            {characterScope.topic_slug && (
              <>
                {' · '}
                <a href={`/${slug}/topics/${characterScope.topic_slug}`}>详述 →</a>
              </>
            )}
          </p>
        </div>
      )
    }
    <div class="bestiary-roster-list">
      {fullRoster.map((item) =>
        item.kind === 'paged' ? (
          <a
            href={item.href}
            class:list={['chip', 'chip-mini', item.entityType === 'monster' && 'chip-monster']}
            title={item.summary}
          >
            {item.name}
          </a>
        ) : (
          <span
            class="chip chip-mini chip-pending"
            title={
              [
                item.note,
                item.appear_in.length > 0 ? `提及：${item.appear_in.slice(0, 4).join('、')}${item.appear_in.length > 4 ? '…' : ''}` : '待补建',
                '待补建',
              ]
                .filter(Boolean)
                .join(' · ')
            }
          >
            {item.name}
            <span class="chip-pending-tag">待补建</span>
          </span>
        )
      )}
    </div>
  </details>

  {
    slug === 'jinpingmei' && (
      <div class="text-muted mb-6 flex flex-wrap gap-2 text-xs">
        <span class="chip">亲缘 = 西门府内</span>
        <span class="chip">雇佣 = 仆佣</span>
        <span class="chip">利益交换 = 帮闲/商贾</span>
        <span class="chip">外人 = 政敌或远端</span>
      </div>
    )
  }

  <div class="bestiary-switcher mb-6">
    {groupings.length > 1 && (
      <div class="bestiary-tabs" role="tablist" aria-label="分组依据">
        <span class="bestiary-tabs-label">分组依据</span>
        {groupings.map((g, i) => (
          <button
            type="button"
            class="bestiary-tab"
            role="tab"
            data-grouping-tab={g.key}
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {g.label}
            <span class="bestiary-tab-count">{g.sections.length}</span>
          </button>
        ))}
      </div>
    )}
    <div class="bestiary-controls-btns">
      <button type="button" class="bestiary-control-btn" data-bestiary-expand="all">全部展开</button>
      <button type="button" class="bestiary-control-btn" data-bestiary-expand="none">全部折叠</button>
    </div>
  </div>

  {
    groupings.map((g, i) => (
      <div
        class="bestiary-grouping"
        data-grouping={g.key}
        hidden={i !== 0}
        data-pagefind-ignore={i !== 0 ? 'true' : undefined}
      >
        {g.sections.map(({ label, items }) => (
          <details class="bestiary-section bestiary-group surface mb-6" open>
            <summary class="bestiary-group-summary">
              <span class="bestiary-group-title">{label}</span>
              <span class="bestiary-group-count">{items.length}</span>
            </summary>
            <div class="bestiary-grid grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
              {items.map((c) => (
                <CharacterCard {...cardProps(c)} />
              ))}
            </div>
          </details>
        ))}
      </div>
    ))
  }
  </div>

  <script>
    const groupings = Array.from(document.querySelectorAll('.bestiary-grouping'));
    const tabs = Array.from(document.querySelectorAll('[data-grouping-tab]'));

    function activate(key: string | null) {
      groupings.forEach((g) => {
        (g as HTMLElement).hidden = g.getAttribute('data-grouping') !== key;
      });
      tabs.forEach((t) =>
        t.setAttribute('aria-selected', t.getAttribute('data-grouping-tab') === key ? 'true' : 'false'),
      );
    }

    tabs.forEach((t) =>
      t.addEventListener('click', () => activate(t.getAttribute('data-grouping-tab'))),
    );

    document.querySelectorAll('[data-bestiary-expand]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const open = btn.getAttribute('data-bestiary-expand') === 'all';
        const active =
          document.querySelector('.bestiary-grouping:not([hidden])') ?? document;
        active.querySelectorAll('details.bestiary-group').forEach((d) => {
          (d as HTMLDetailsElement).open = open;
        });
      });
    });
  </script>
</Base>
