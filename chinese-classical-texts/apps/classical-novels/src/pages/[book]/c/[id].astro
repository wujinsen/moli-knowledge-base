---
import { getCollection, render } from 'astro:content';
import { getBooks } from '../../../lib/getBooks';
import Base from '../../../layouts/Base.astro';
import BackLink from '../../../components/BackLink.astro';
import {
  relatedItemsForCharacter,
  relatedTransactionsForCharacter,
  milestoneEventsForCharacter,
} from '../../../lib/crosslinks';
import { likeItemHref } from '../../../lib/bestiary';
import { chapterLabel } from '../../../lib/events';
import { graphFocusHref } from '../../../lib/sna';

export async function getStaticPaths() {
  const books = await getBooks();
  const slugByBook = new Map(books.map((b) => [b.data.book, b.data.slug]));
  const featuresByBook = new Map(books.map((b) => [b.data.book, b.data.features]));
  const chars = await getCollection('characters');
  return chars.map((c) => ({
    params: { book: slugByBook.get(c.data.book)!, id: c.data.id },
    props: {
      entry: c,
      slug: slugByBook.get(c.data.book)!,
      features: featuresByBook.get(c.data.book) ?? [],
    },
  }));
}

const { entry, slug, features } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
const contradictHint =
  d.book === '金瓶梅'
    ? '词话/崇祯/竹坡版本差异（图谱虚线边）'
    : '脂评/探佚与程高本分歧（图谱虚线边）';
const relatedItems = features.includes('items')
  ? await relatedItemsForCharacter(d.book, d.id)
  : [];
const relatedTxs = features.includes('silver')
  ? await relatedTransactionsForCharacter(d.book, d.id)
  : [];
const readEdition = slug === 'jinpingmei' ? 'cihua' : slug === 'honglou' ? 'zhiben' : '1';
const keyEvents = features.includes('saga')
  ? await milestoneEventsForCharacter(d.book, d.id)
  : [];
---

<Base title={d.name} bookSlug={slug} bookName={d.book} features={features}>
  <BackLink href={`/${slug}/bestiary`} label="图鉴" />
  <div
    class="content-page"
    data-pagefind-body
    data-pagefind-meta={`title:${d.name}`}
    data-pagefind-filter={`书:${d.book},类型:${d.type === 'monster' ? '妖怪' : '人物'}`}
  >
  <div class="mt-3 flex items-center gap-3">
    <h1 class="brand text-4xl" style="color: var(--primary)">{d.name}</h1>
    <span class="chip chip-md">{d.type === 'monster' ? '妖怪' : '人物'}</span>
  </div>

  {d.aliases.length > 0 && <p class="mt-2 text-sm">别名：{d.aliases.join('、')}</p>}

  <div class="entity-spec surface mt-4 grid gap-2.5 p-4 sm:grid-cols-2 sm:p-5">
    {d.faction && <div>阵营：{d.faction}</div>}
    {d.ximen_proximity && <div>西门府距离：{d.ximen_proximity}</div>}
    {d.first_appear && <div>首次登场：{d.first_appear}</div>}
    {d.靠山 && <div>靠山：{d.靠山}</div>}
    {d.依附 && <div>依附：{d.依附}</div>}
    {d.洞府 && <div>洞府：{d.洞府}</div>}
    {d.原型 && <div>原型：{d.原型}</div>}
    {d.能力.length > 0 && <div>能力：{d.能力.join('、')}</div>}
    {d.法宝.length > 0 && <div>法宝：{d.法宝.join('、')}</div>}
    {d.结局 && <div>结局：{d.结局}</div>}
    {d.收服者 && <div>收服者：{d.收服者}</div>}
    {d.性格 && <div class="sm:col-span-2">性格：{d.性格}</div>}
    {
      d.服饰.length > 0 && (
        <div class="sm:col-span-2">
          服饰：
          {d.服饰.map((item, i) => {
            const itemHref = likeItemHref(slug, item);
            return (
              <>
                {i > 0 && '、'}
                {itemHref ? (
                  <a class="hover:underline" style="color: var(--accent)" href={itemHref}>
                    {item}
                  </a>
                ) : (
                  item
                )}
              </>
            );
          })}
        </div>
      )
    }
    {
      d.关键物品.length > 0 && (
        <div class="sm:col-span-2">
          关键物品：
          {d.关键物品.map((item, i) => {
            const itemHref = likeItemHref(slug, item);
            return (
              <>
                {i > 0 && '、'}
                {itemHref ? (
                  <a class="hover:underline" style="color: var(--accent)" href={itemHref}>
                    {item}
                  </a>
                ) : (
                  item
                )}
              </>
            );
          })}
        </div>
      )
    }
    {
      d.喜好.length > 0 && (
        <div class="sm:col-span-2">
          喜好：
          {d.喜好.map((like, i) => {
            const itemHref = likeItemHref(slug, like);
            return (
              <>
                {i > 0 && '、'}
                {itemHref ? (
                  <a class="hover:underline" style="color: var(--accent)" href={itemHref}>
                    {like}
                  </a>
                ) : (
                  like
                )}
              </>
            );
          })}
        </div>
      )
    }
  </div>

  {
    d.arc.length > 0 && (
      <a
        href={`/${slug}/lifeline/${d.id}`}
        class="surface mt-4 flex items-center gap-3 px-4 py-3 hover:opacity-90"
        style="border-left: 3px solid var(--primary)"
      >
        <span class="glyph shrink-0" style="width:2.4rem;height:2.4rem;font-size:1.3rem">途</span>
        <span class="min-w-0">
          <span class="font-bold" style="color: var(--primary)">人生轨迹 · 命运曲线</span>
          <span class="block text-sm text-muted">
            {d.arc.length} 个节点，从「{d.arc[0].title}」到「{d.arc[d.arc.length - 1].title}」 →
          </span>
        </span>
      </a>
    )
  }

  {
    d.relations.length > 0 && (
      <div class="mt-6">
        <h2 class="section-title mb-2">关系</h2>
        <ul class="flex flex-wrap gap-2">
          {d.relations.map((r) => (
            <li>
              <a class="chip hover:underline" href={`/${slug}/c/${r.target}`}>
                {r.type}{r.role ? `·${r.role}` : ''} → {r.target}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  {
    keyEvents.length > 0 && (
      <div class="mt-6">
        <h2 class="section-title mb-2">关键事件</h2>
        <ul class="space-y-2">
          {keyEvents.map((ev) => (
            <li class="surface px-3 py-2">
              <a class="hover:underline" style="color: var(--primary)" href={`/${slug}/e/${ev.id}`}>{ev.title}</a>
              <span class="ml-1 chip text-xs">{chapterLabel(ev.chapters)}</span>
              {ev.summary && <span class="ml-1 text-sm text-muted">· {ev.summary}</span>}
            </li>
          ))}
        </ul>
        <div class="mt-2 flex flex-wrap gap-3 text-sm">
          <a href={`/${slug}/saga`} class="hover:underline" style="color: var(--accent)">查看大事记 →</a>
          {features.includes('graph') && (
            <a href={graphFocusHref(slug, d.id)} class="hover:underline" style="color: var(--accent)">在关系图谱中查看 →</a>
          )}
        </div>
      </div>
    )
  }

  {
    relatedItems.length > 0 && (
      <div class="mt-6">
        <h2 class="section-title mb-2">相关名物</h2>
        <ul class="flex flex-wrap gap-2">
          {relatedItems.map((item) => (
            <li>
              <a class="chip hover:underline" href={`/${slug}/i/${item.id}`}>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  {
    relatedTxs.length > 0 && (
      <div class="mt-6">
        <h2 class="section-title mb-2">白银交易</h2>
        <ul class="space-y-2">
          {relatedTxs.map((tx) => (
            <li class="surface px-3 py-2">
              <a
                class="hover:underline"
                style="color: var(--primary)"
                href={`/${slug}/read/${readEdition}/${tx.chapter}`}
              >
                第{tx.chapter}回
              </a>
              <span> · {tx.summary}</span>
              {tx.amount && <span class="ml-1 chip">{tx.amount}</span>}
            </li>
          ))}
        </ul>
        <a href={`/${slug}/silver`} class="mt-2 inline-block text-sm hover:underline" style="color: var(--accent)">
          查看白银流 →
        </a>
      </div>
    )
  }

  {
    d.variants.length > 0 && (
      <div class="surface mt-6 p-4" style="border-color: var(--gold)">
        <h2 class="mb-1 font-bold" style="color: var(--primary)">版本异文</h2>
        <ul>
          {d.variants.map((v) => (
            <li>【{v.edition}】{v.claim}{v.source ? `（${v.source}）` : ''}</li>
          ))}
        </ul>
        {d.contradicts.length > 0 && (
          <div class="mt-3 border-t pt-3" style="border-color: var(--gold)">
            <span>版本争议（{contradictHint}）：</span>
            {d.contradicts.map((c) => (
              <a class="chip ml-1 hover:underline" href={`/${slug}/graph`}>{c}</a>
            ))}
          </div>
        )}
      </div>
    )
  }

  {
    d.variants.length === 0 && d.contradicts.length > 0 && (
      <div class="surface mt-6 p-4" style="border-color: var(--gold)">
        <h2 class="mb-1 font-bold" style="color: var(--primary)">版本争议</h2>
        <div>
          <span>{contradictHint}：</span>
          {d.contradicts.map((c) => (
            <a class="chip ml-1 hover:underline" href={`/${slug}/graph`}>{c}</a>
          ))}
        </div>
      </div>
    )
  }

  <article class="prose-cn mt-6 max-w-none">
    <Content />
  </article>
  </div>
</Base>
