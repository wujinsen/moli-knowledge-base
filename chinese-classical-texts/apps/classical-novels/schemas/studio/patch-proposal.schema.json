{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moli-knowledge-base.local/schemas/studio/patch-proposal.schema.json",
  "title": "PatchProposal",
  "description": "维护台 propose_patch 产出；用户批准前不得写入 git（v0.1）",
  "type": "object",
  "required": [
    "proposalId",
    "sessionId",
    "status",
    "intent",
    "title",
    "summary",
    "sources",
    "patches",
    "postApply",
    "actions"
  ],
  "properties": {
    "proposalId": { "type": "string", "minLength": 8 },
    "sessionId": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["pending", "applied", "partially_applied", "discarded", "failed"]
    },
    "intent": {
      "type": "string",
      "enum": [
        "fix_key_item",
        "fix_costume",
        "add_plot_bullet",
        "query",
        "topic_fill",
        "ingest_chapter",
        "dream_batch"
      ]
    },
    "title": { "type": "string", "maxLength": 120 },
    "summary": { "type": "string", "maxLength": 500 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/SourceCitation" }
    },
    "patches": {
      "type": "array",
      "items": { "$ref": "#/$defs/FilePatch" }
    },
    "postApply": { "$ref": "#/$defs/PostApply" },
    "guardPreview": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pass", "warn", "fail", "skipped"] },
        "checked": { "type": "integer", "minimum": 0 },
        "unverified": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "kind": { "type": "string" },
              "entityId": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "topicFillSuggestion": {
      "type": "object",
      "description": "仅 query 意图可选",
      "properties": {
        "path": { "type": "string" },
        "title": { "type": "string" },
        "derived_from": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "bodyMarkdown": { "type": "string" }
      }
    },
    "actions": {
      "type": "object",
      "required": ["canApply", "canDiscard"],
      "properties": {
        "canApply": { "type": "boolean" },
        "canApplyPartial": { "type": "boolean" },
        "canEdit": { "type": "boolean" },
        "canDiscard": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "SourceCitation": {
      "type": "object",
      "required": ["chapter", "path"],
      "properties": {
        "chapter": { "type": "integer", "minimum": 1 },
        "path": { "type": "string" },
        "edition": { "type": "string" },
        "excerpt": { "type": "string", "maxLength": 400 },
        "readUrl": { "type": "string" }
      }
    },
    "FilePatch": {
      "type": "object",
      "required": ["path", "operation", "diff"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^src/(content|data)/"
        },
        "operation": { "type": "string", "enum": ["create", "update"] },
        "hunkSummary": { "type": "string", "maxLength": 200 },
        "diff": { "type": "string", "description": "Unified diff UTF-8" }
      }
    },
    "PostApply": {
      "type": "object",
      "required": ["scripts", "logEntry"],
      "properties": {
        "scripts": {
          "type": "array",
          "items": { "type": "string" },
          "description": "相对于 apps/classical-novels 的工作目录命令"
        },
        "logEntry": {
          "type": "string",
          "pattern": "^## \\[\\d{4}-\\d{2}-\\d{2}\\] studio \\|"
        },
        "refreshHints": {
          "type": "object",
          "properties": {
            "snapshots": { "type": "boolean" },
            "relations": { "type": "boolean" },
            "bestiary": { "type": "boolean" }
          }
        }
      }
    }
  }
}
